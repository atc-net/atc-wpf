<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfHardware.Demos.HotPlugInUseDemoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <atc:GridEx Margin="16" Columns="*,16,*" Rows="Auto,Auto,*">

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="0,0,0,12"
            FontSize="16"
            FontWeight="SemiBold"
            Text="Hot-plug &amp; In-Use Demo" />

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="0,0,0,12"
            FontStyle="Italic"
            Foreground="{DynamicResource AtcApps.Brushes.Gray5}"
            Text="Plug / unplug hardware to see ValueChanged, DeviceLost, DeviceReconnected and DeviceStateChanged routed events fire. Open another app holding the device (e.g. another COM-port app) to trigger 'In use'."
            TextWrapping="Wrap" />

        <atc:UniformSpacingPanel
            Grid.Row="2"
            Grid.Column="0"
            Spacing="12">

            <atc:LabelSerialPortPicker
                x:Name="SerialPicker"
                DetectInUseState="True"
                LabelText="Serial port" />

            <atc:LabelUsbPortPicker
                x:Name="UsbPicker"
                LabelText="USB device" />

            <atc:LabelUsbCameraPicker
                x:Name="CameraPicker"
                LabelText="Camera" />

        </atc:UniformSpacingPanel>

        <atc:GridEx
            Grid.Row="2"
            Grid.Column="2"
            Rows="Auto,*">

            <atc:GridEx
                Grid.Row="0"
                Margin="0,0,0,8"
                Columns="*,Auto">
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Event log" />
                <Button
                    Grid.Column="1"
                    Padding="10,4"
                    Click="OnClearClick"
                    Content="Clear" />
            </atc:GridEx>

            <ListBox
                x:Name="EventLog"
                Grid.Row="1"
                FontFamily="Consolas"
                FontSize="12"
                ItemsSource="{Binding Entries}"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </atc:GridEx>

    </atc:GridEx>
</UserControl>