<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Viewers.JsonViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewers="clr-namespace:Atc.Wpf.Components.Viewers;assembly=Atc.Wpf.Components"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    xmlns:vm="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Viewers"
    d:DataContext="{d:DesignInstance Type=vm:JsonViewerViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:JsonViewerViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <viewers:JsonViewer
                    Data="{Binding Path=JsonData}"
                    ShowActionAndInformationBar="{Binding ShowActionAndInformationBar}"
                    StartExpanded="{Binding StartExpanded}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>