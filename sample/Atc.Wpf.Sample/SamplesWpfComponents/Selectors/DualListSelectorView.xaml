<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Selectors.DualListSelectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Selectors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:DualListSelectorDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:DualListSelector
                    x:Name="InteractiveDualListSelector"
                    Margin="10"
                    AllowDragDrop="{Binding AllowDragDrop}"
                    AllowMultiSelect="{Binding AllowMultiSelect}"
                    AutoRecalculateSortOrder="{Binding AutoRecalculateSortOrder}"
                    AvailableHeader="Available Permissions"
                    LayoutMode="{Binding LayoutMode}"
                    SelectedHeader="Granted Permissions"
                    ShowFilter="{Binding ShowFilter}"
                    ShowItemCount="{Binding ShowItemCount}"
                    ShowReorderButtons="{Binding ShowReorderButtons}"
                    ShowTransferAllButtons="{Binding ShowTransferAllButtons}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>

</UserControl>