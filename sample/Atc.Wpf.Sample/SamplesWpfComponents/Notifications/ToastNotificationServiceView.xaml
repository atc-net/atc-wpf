<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Notifications.ToastNotificationServiceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notifications="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Notifications"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <notifications:ToastNotificationServiceViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <DockPanel x:Name="InteractiveToastServiceDemo" Margin="20">

                    <atc:UniformSpacingPanel
                        DockPanel.Dock="Left"
                        Orientation="Vertical"
                        Spacing="20">

                        <atc:UniformSpacingPanel
                            ItemWidth="100"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Button
                                Command="{Binding ShowInformationCommand}"
                                Content="Information"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                Command="{Binding ShowSuccessCommand}"
                                Content="Success"
                                Style="{StaticResource ButtonSuccess}" />
                            <Button
                                Command="{Binding ShowWarningCommand}"
                                Content="Warning"
                                Style="{StaticResource ButtonWarning}" />
                            <Button
                                Command="{Binding ShowErrorCommand}"
                                Content="Error"
                                Style="{StaticResource ButtonDanger}" />
                        </atc:UniformSpacingPanel>

                        <Button
                            MinWidth="100"
                            Command="{Binding ShowDesktopCommand}"
                            Content="Desktop"
                            Style="{StaticResource ButtonInfo}" />

                        <atc:UniformSpacingPanel
                            ItemWidth="130"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Button
                                Command="{Binding ShowCustomDurationCommand}"
                                Content="10s Duration" />
                            <Button
                                Command="{Binding ShowWithClickActionCommand}"
                                Content="Click Action" />
                        </atc:UniformSpacingPanel>
                    </atc:UniformSpacingPanel>

                    <atc:ToastNotificationArea
                        x:Name="ServiceArea"
                        MaxItems="5"
                        Position="TopRight" />
                </DockPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>