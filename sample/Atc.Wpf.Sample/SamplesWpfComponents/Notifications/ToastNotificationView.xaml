<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Notifications.ToastNotificationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notifications="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Notifications"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    x:Name="UcBusyOverlayView"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <notifications:ToastNotificationViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <DockPanel x:Name="InteractiveToastDemo" Margin="50">

                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="50">
                        <atc:UniformSpacingPanel
                            ItemWidth="100"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Button
                                Command="{Binding WindowInformationCommand}"
                                Content="Information"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                Command="{Binding WindowSuccessCommand}"
                                Content="Success"
                                Style="{StaticResource ButtonSuccess}" />
                            <Button
                                Command="{Binding WindowWarningCommand}"
                                Content="Warning"
                                Style="{StaticResource ButtonWarning}" />
                            <Button
                                Command="{Binding WindowErrorCommand}"
                                Content="Error"
                                Style="{StaticResource ButtonDanger}" />
                        </atc:UniformSpacingPanel>

                        <atc:UniformSpacingPanel
                            ItemWidth="100"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Button
                                Command="{Binding DesktopInformationCommand}"
                                Content="Information"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                Command="{Binding DesktopSuccessCommand}"
                                Content="Success"
                                Style="{StaticResource ButtonSuccess}" />
                            <Button
                                Command="{Binding DesktopWarningCommand}"
                                Content="Warning"
                                Style="{StaticResource ButtonWarning}" />
                            <Button
                                Command="{Binding DesktopErrorCommand}"
                                Content="Error"
                                Style="{StaticResource ButtonDanger}" />
                        </atc:UniformSpacingPanel>
                    </atc:UniformSpacingPanel>

                    <atc:ToastNotificationArea
                        x:Name="WindowArea"
                        MaxItems="3"
                        Position="TopLeft" />
                </DockPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>