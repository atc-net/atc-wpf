<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Zoom.ZoomBrowserViewSampleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Zoom"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:zoom="clr-namespace:Atc.Wpf.Controls.Zoom;assembly=Atc.Wpf.Controls"
    d:DataContext="{d:DesignInstance Type=local:ZoomBrowserViewSampleViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <local:ZoomBrowserViewSampleViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,300">

        <!--  Left: ZoomBrowserView  -->
        <atc:ZoomBrowserView
            Grid.Column="0"
            ShowMiniMap="{Binding ShowMiniMap}"
            ShowStatusBar="{Binding ShowStatusBar}"
            ShowToolbar="{Binding ShowToolbar}">
            <atc:ZoomBrowserView.ZoomContent>
                <zoom:ZoomScrollViewer ZoomInitialPosition="FitScreen">
                    <Canvas Width="800" Height="600">
                        <Rectangle
                            Canvas.Left="50"
                            Canvas.Top="50"
                            Width="200"
                            Height="150"
                            Fill="#FF4A90D9"
                            RadiusX="10"
                            RadiusY="10"
                            Stroke="#FF2D5F8A"
                            StrokeThickness="2" />
                        <Ellipse
                            Canvas.Left="350"
                            Canvas.Top="80"
                            Width="180"
                            Height="180"
                            Fill="#FF7BC67E"
                            Stroke="#FF4A8B4D"
                            StrokeThickness="2" />
                        <Polygon
                            Fill="#FFE8A838"
                            Points="600,50 700,200 500,200"
                            Stroke="#FFB8842A"
                            StrokeThickness="2" />
                        <TextBlock
                            Canvas.Left="100"
                            Canvas.Top="300"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="#FF333333"
                            Text="ZoomBrowserView Demo" />
                        <TextBlock
                            Canvas.Left="100"
                            Canvas.Top="350"
                            FontSize="16"
                            Foreground="#FF666666"
                            Text="Ctrl+Scroll to zoom, Ctrl+Drag or Space+Drag to pan, Shift+Scroll to pan horizontally" />
                        <Rectangle
                            Canvas.Left="50"
                            Canvas.Top="460"
                            Width="700"
                            Height="100"
                            Fill="#FFD64545"
                            RadiusX="5"
                            RadiusY="5"
                            Stroke="#FFB33636"
                            StrokeThickness="2" />
                        <TextBlock
                            Canvas.Left="300"
                            Canvas.Top="495"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Bottom Area" />
                    </Canvas>
                </zoom:ZoomScrollViewer>
            </atc:ZoomBrowserView.ZoomContent>
        </atc:ZoomBrowserView>

        <!--  Right: Settings  -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <atc:UniformSpacingPanel
                Margin="10"
                Orientation="Vertical"
                VerticalSpacing="8">

                <GroupBox
                    atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
                    Header="Visibility">
                    <atc:UniformSpacingPanel Orientation="Vertical" VerticalSpacing="8">
                        <CheckBox Content="Show Toolbar" IsChecked="{Binding ShowToolbar}" />
                        <CheckBox Content="Show MiniMap" IsChecked="{Binding ShowMiniMap}" />
                        <CheckBox Content="Show Status Bar" IsChecked="{Binding ShowStatusBar}" />
                    </atc:UniformSpacingPanel>
                </GroupBox>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

    </atc:GridEx>

</UserControl>