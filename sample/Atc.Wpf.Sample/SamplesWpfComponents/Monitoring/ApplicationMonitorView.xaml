<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Monitoring.ApplicationMonitorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:monitoring="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Monitoring"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=monitoring:ApplicationMonitorDemoViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <atc:ApplicationMonitorView
            Grid.Column="0"
            Margin="10"
            AreaColumnWidth="{Binding DataContext.AreaColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
            DataContext="{Binding Path=ApplicationMonitorViewModel}"
            MessageColumnWidth="{Binding DataContext.MessageColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
            ShowAutoScrollInToolbar="{Binding DataContext.ShowAutoScrollInToolbar, RelativeSource={RelativeSource AncestorType=UserControl}}"
            ShowClearInToolbar="{Binding DataContext.ShowClearInToolbar, RelativeSource={RelativeSource AncestorType=UserControl}}"
            ShowSearchInToolbar="{Binding DataContext.ShowSearchInToolbar, RelativeSource={RelativeSource AncestorType=UserControl}}"
            ShowToolbar="{Binding DataContext.ShowToolbar, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}">
            <sample:SampleSidePanel.ActionsContent>
                <atc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                    <Button Command="{Binding Path=AddOneCommand}" Content="Add 1 item" />
                    <Button Command="{Binding Path=AddManyCommand}" Content="Add many items" />
                </atc:UniformSpacingPanel>
            </sample:SampleSidePanel.ActionsContent>
        </sample:SampleSidePanel>

    </atc:GridEx>

</UserControl>