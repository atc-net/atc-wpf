<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfComponents.Flyouts.FlyoutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:flyouts="clr-namespace:Atc.Wpf.Components.Flyouts;assembly=Atc.Wpf.Components"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfComponents.Flyouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:FlyoutDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <TextBlock TextWrapping="Wrap">
                    The Flyout control provides a sliding panel overlay that slides in from an edge of its container.
                    It supports light dismiss behavior (click outside or press Escape), customizable animations,
                    overlay backgrounds, and can slide in from any edge (Right, Left, Top, Bottom, Center).
                    Features include pin/unpin, resizable panels, custom animations, and attached flyout support.
                    The default position is Right, similar to the Azure Portal design pattern.
                </TextBlock>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Click the button below to open a basic flyout sliding in from the right edge."
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenRightFlyoutButton"
                        Width="200"
                        HorizontalAlignment="Left"
                        Click="OpenRightFlyoutButton_Click"
                        Content="Open Right Flyout" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Flyouts can slide in from any edge of their container."
                        TextWrapping="Wrap" />
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="10"
                        Orientation="Horizontal"
                        VerticalSpacing="10">
                        <Button
                            x:Name="OpenLeftFlyoutButton"
                            Width="120"
                            Click="OpenLeftFlyoutButton_Click"
                            Content="Left" />
                        <Button
                            x:Name="OpenTopFlyoutButton"
                            Width="120"
                            Click="OpenTopFlyoutButton_Click"
                            Content="Top" />
                        <Button
                            x:Name="OpenBottomFlyoutButton"
                            Width="120"
                            Click="OpenBottomFlyoutButton_Click"
                            Content="Bottom" />
                        <Button
                            x:Name="OpenCenterFlyoutButton"
                            Width="120"
                            Click="OpenCenterFlyoutButton_Click"
                            Content="Center" />
                    </atc:UniformSpacingPanel>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Advanced flyout features: pin/unpin to prevent light dismiss, resizable panels, and custom animations."
                        TextWrapping="Wrap" />
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="10"
                        Orientation="Horizontal"
                        VerticalSpacing="10">
                        <Button
                            x:Name="OpenPinnableFlyoutButton"
                            Width="150"
                            Click="OpenPinnableFlyoutButton_Click"
                            Content="Pinnable Flyout" />
                        <Button
                            x:Name="OpenResizableFlyoutButton"
                            Width="150"
                            Click="OpenResizableFlyoutButton_Click"
                            Content="Resizable Flyout" />
                        <Button
                            x:Name="OpenBouncyFlyoutButton"
                            Width="150"
                            Click="OpenBouncyFlyoutButton_Click"
                            Content="Bouncy Animation" />
                    </atc:UniformSpacingPanel>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Use FlyoutBase.AttachedFlyout and FlyoutBase.OpenOnClick to attach flyouts directly to buttons."
                        TextWrapping="Wrap" />
                    <Button
                        Width="200"
                        HorizontalAlignment="Left"
                        flyouts:FlyoutBase.OpenOnClick="True"
                        Content="Click Me (Attached Flyout)">
                        <flyouts:FlyoutBase.AttachedFlyout>
                            <flyouts:Flyout FlyoutWidth="350" Header="Attached Flyout">
                                <StackPanel Margin="16">
                                    <TextBlock
                                        Margin="0,0,0,16"
                                        Text="This flyout is attached directly to the button using FlyoutBase.AttachedFlyout."
                                        TextWrapping="Wrap" />
                                    <TextBlock Text="No code-behind needed - just set FlyoutBase.OpenOnClick=True!" TextWrapping="Wrap" />
                                </StackPanel>
                            </flyouts:Flyout>
                        </flyouts:FlyoutBase.AttachedFlyout>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Flyouts can be configured with various options like width, overlay, and light dismiss behavior."
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenConfiguredFlyoutButton"
                        Width="200"
                        HorizontalAlignment="Left"
                        Click="OpenConfiguredFlyoutButton_Click"
                        Content="Open Configured Flyout" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Flyouts are commonly used to display forms or settings panels."
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenFormFlyoutButton"
                        Width="200"
                        HorizontalAlignment="Left"
                        Click="OpenFormFlyoutButton_Click"
                        Content="Open Settings Panel" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Flyouts can be nested to create drill-down experiences like the Azure Portal. Click a button in a flyout to open another flyout on top."
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenNestedFlyoutButton"
                        Width="200"
                        HorizontalAlignment="Left"
                        Click="OpenNestedFlyoutButton_Click"
                        Content="Open Nested Demo" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="FlyoutPresenter provides a standardized layout with header, scrollable content, and footer sections. Great for forms with action buttons."
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenPresenterFlyoutButton"
                        Width="200"
                        HorizontalAlignment="Left"
                        Click="OpenPresenterFlyoutButton_Click"
                        Content="Open FlyoutPresenter Demo" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="When IsFocusTrapEnabled is true (default), Tab/Shift+Tab navigation stays within the flyout. Disable it to allow tabbing out of the flyout."
                        TextWrapping="Wrap" />
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="10"
                        Orientation="Horizontal"
                        VerticalSpacing="10">
                        <Button
                            x:Name="OpenFocusTrappedFlyoutButton"
                            Width="180"
                            Click="OpenFocusTrappedFlyoutButton_Click"
                            Content="Focus Trapped (Default)" />
                        <Button
                            x:Name="OpenFocusFreeFlyoutButton"
                            Width="180"
                            Click="OpenFocusFreeFlyoutButton_Click"
                            Content="Focus Free" />
                    </atc:UniformSpacingPanel>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,10"
                        Text="Flyouts support full color customization through properties like FlyoutBackground, FlyoutBorderBrush, HeaderBackground, HeaderForeground, HeaderBorderBrush, and OverlayBrush."
                        TextWrapping="Wrap" />
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="10"
                        Orientation="Horizontal"
                        VerticalSpacing="10">
                        <Button
                            x:Name="OpenBrandedFlyoutButton"
                            Width="140"
                            Click="OpenBrandedFlyoutButton_Click"
                            Content="Branded (Blue)" />
                        <Button
                            x:Name="OpenSuccessFlyoutButton"
                            Width="140"
                            Click="OpenSuccessFlyoutButton_Click"
                            Content="Success (Green)" />
                        <Button
                            x:Name="OpenWarningFlyoutButton"
                            Width="140"
                            Click="OpenWarningFlyoutButton_Click"
                            Content="Warning (Orange)" />
                        <Button
                            x:Name="OpenErrorFlyoutButton"
                            Width="140"
                            Click="OpenErrorFlyoutButton_Click"
                            Content="Error (Red)" />
                    </atc:UniformSpacingPanel>
                </StackPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <!--  Right Flyout  -->
        <flyouts:Flyout
            x:Name="RightFlyout"
            FlyoutWidth="400"
            Header="Right Flyout"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This is a basic flyout that slides in from the right edge."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Click outside, press Escape, or click the close button to dismiss."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=RightFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Left Flyout  -->
        <flyouts:Flyout
            x:Name="LeftFlyout"
            FlyoutWidth="350"
            Header="Left Flyout"
            Position="Left">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This flyout slides in from the left edge."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=LeftFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Top Flyout  -->
        <flyouts:Flyout
            x:Name="TopFlyout"
            FlyoutHeight="200"
            Header="Top Flyout"
            Position="Top">
            <StackPanel Margin="16" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Text="This flyout slides in from the top edge."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    VerticalAlignment="Center"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=TopFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Bottom Flyout  -->
        <flyouts:Flyout
            x:Name="BottomFlyout"
            FlyoutHeight="200"
            Header="Bottom Flyout"
            Position="Bottom">
            <StackPanel Margin="16" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Text="This flyout slides in from the bottom edge."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    VerticalAlignment="Center"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=BottomFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Configured Flyout  -->
        <flyouts:Flyout
            x:Name="ConfiguredFlyout"
            FlyoutWidth="{Binding FlyoutWidth}"
            Header="Configured Flyout"
            IsLightDismissEnabled="{Binding IsLightDismissEnabled}"
            Position="Right"
            ShowCloseButton="{Binding ShowCloseButton}"
            ShowOverlay="{Binding ShowOverlay}">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This flyout is configured based on the options above."
                    TextWrapping="Wrap" />
                <TextBlock Margin="0,0,0,8" Text="Current Settings:" />
                <TextBlock Text="{Binding FlyoutWidth, StringFormat=Width: {0:F0}px}" />
                <TextBlock Text="{Binding ShowOverlay, StringFormat=Show Overlay: {0}}" />
                <TextBlock Text="{Binding IsLightDismissEnabled, StringFormat=Light Dismiss: {0}}" />
                <TextBlock Text="{Binding ShowCloseButton, StringFormat=Show Close Button: {0}}" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=ConfiguredFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Form Flyout  -->
        <flyouts:Flyout
            x:Name="FormFlyout"
            FlyoutWidth="450"
            Header="Settings"
            Position="Right">
            <atc:GridEx Margin="16" Rows="Auto,Auto,Auto,Auto,Auto,*,Auto">

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="General Settings" />

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Margin="0,0,0,4" Text="Display Name" />
                    <TextBox Text="John Doe" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Margin="0,0,0,4" Text="Email Address" />
                    <TextBox Text="john@example.com" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,12">
                    <TextBlock Margin="0,0,0,4" Text="Theme" />
                    <ComboBox SelectedIndex="0">
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                        <ComboBoxItem Content="System" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,12">
                    <CheckBox Content="Enable notifications" IsChecked="True" />
                    <CheckBox
                        Margin="0,8,0,0"
                        Content="Auto-save documents"
                        IsChecked="True" />
                    <CheckBox Margin="0,8,0,0" Content="Show welcome screen on startup" />
                </StackPanel>

                <StackPanel
                    Grid.Row="6"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="80"
                        Margin="0,0,8,0"
                        Click="CloseFlyout_Click"
                        Content="Cancel"
                        Tag="{Binding ElementName=FormFlyout}" />
                    <Button
                        Width="80"
                        Click="SaveAndCloseFlyout_Click"
                        Content="Save"
                        Tag="{Binding ElementName=FormFlyout}" />
                </StackPanel>
            </atc:GridEx>
        </flyouts:Flyout>

        <!--  Nested Flyout Level 1  -->
        <flyouts:Flyout
            x:Name="NestedFlyout1"
            FlyoutWidth="500"
            Header="Resource Group"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Resource Group Details" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This is the first level flyout. Click a resource below to see its details in a nested flyout."
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,0,0,8"
                    Padding="12"
                    Background="{DynamicResource AtcApps.Brushes.Gray9}"
                    CornerRadius="4"
                    Cursor="Hand"
                    MouseLeftButtonUp="OpenNestedFlyout2_Click">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Virtual Machine 1" />
                        <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Standard_DS2_v2 - Running" />
                    </StackPanel>
                </Border>

                <Border
                    Margin="0,0,0,8"
                    Padding="12"
                    Background="{DynamicResource AtcApps.Brushes.Gray9}"
                    CornerRadius="4"
                    Cursor="Hand"
                    MouseLeftButtonUp="OpenNestedFlyout2_Click">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Storage Account" />
                        <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Standard_LRS - Active" />
                    </StackPanel>
                </Border>

                <Border
                    Margin="0,0,0,8"
                    Padding="12"
                    Background="{DynamicResource AtcApps.Brushes.Gray9}"
                    CornerRadius="4"
                    Cursor="Hand"
                    MouseLeftButtonUp="OpenNestedFlyout2_Click">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="SQL Database" />
                        <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Basic - Online" />
                    </StackPanel>
                </Border>

                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=NestedFlyout1}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Nested Flyout Level 2  -->
        <flyouts:Flyout
            x:Name="NestedFlyout2"
            FlyoutWidth="450"
            Header="Resource Details"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Virtual Machine Details" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This is the second level flyout. Click below to see more details."
                    TextWrapping="Wrap" />

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Status" />
                    <TextBlock FontWeight="SemiBold" Text="Running" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Size" />
                    <TextBlock FontWeight="SemiBold" Text="Standard_DS2_v2" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Location" />
                    <TextBlock FontWeight="SemiBold" Text="West Europe" />
                </StackPanel>

                <Button
                    Width="150"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="OpenNestedFlyout3_Click"
                    Content="View Metrics" />

                <Button
                    Width="100"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=NestedFlyout2}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Nested Flyout Level 3  -->
        <flyouts:Flyout
            x:Name="NestedFlyout3"
            FlyoutWidth="400"
            Header="Metrics"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Performance Metrics" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This is the third level flyout. You can nest as deep as needed."
                    TextWrapping="Wrap" />

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="CPU Usage" />
                    <TextBlock FontWeight="SemiBold" Text="23%" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Memory Usage" />
                    <TextBlock FontWeight="SemiBold" Text="4.2 GB / 8 GB" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Network In" />
                    <TextBlock FontWeight="SemiBold" Text="1.2 MB/s" />
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Foreground="{DynamicResource AtcApps.Brushes.Gray3}" Text="Network Out" />
                    <TextBlock FontWeight="SemiBold" Text="0.8 MB/s" />
                </StackPanel>

                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=NestedFlyout3}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Center Flyout (modal-like)  -->
        <flyouts:Flyout
            x:Name="CenterFlyout"
            CornerRadius="8"
            FlyoutHeight="350"
            FlyoutWidth="500"
            Header="Centered Dialog"
            Position="Center">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Centered Flyout" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This flyout appears centered with a scale animation, similar to a modal dialog."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Great for confirmation dialogs or focused tasks that don't need slide-in behavior."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=CenterFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Pinnable Flyout  -->
        <flyouts:Flyout
            x:Name="PinnableFlyout"
            FlyoutWidth="400"
            Header="Pinnable Panel"
            Position="Right"
            ShowPinButton="True">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Pin/Unpin Feature" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Click the pin icon in the header to pin this flyout. When pinned, light dismiss is disabled - clicking outside won't close it."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Click the pin again to unpin and restore normal light dismiss behavior."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=PinnableFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Resizable Flyout  -->
        <flyouts:Flyout
            x:Name="ResizableFlyout"
            FlyoutWidth="400"
            Header="Resizable Panel"
            IsResizable="True"
            MaxFlyoutWidth="700"
            MinFlyoutWidth="250"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Resizable Flyout" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Drag the left edge of this flyout to resize it. The width is constrained between 250px and 700px."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This is useful when users need to see more or less content based on their preference."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=ResizableFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Bouncy Animation Flyout  -->
        <flyouts:Flyout
            x:Name="BouncyFlyout"
            AnimationDuration="600"
            FlyoutWidth="400"
            Header="Custom Animation"
            Position="Right">
            <flyouts:Flyout.EasingFunction>
                <ElasticEase
                    EasingMode="EaseOut"
                    Oscillations="2"
                    Springiness="5" />
            </flyouts:Flyout.EasingFunction>
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Custom Animation" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="This flyout uses an ElasticEase animation for a bouncy effect when opening."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="You can customize the animation by setting the EasingFunction property to any IEasingFunction."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=BouncyFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  FlyoutPresenter Demo  -->
        <flyouts:Flyout
            x:Name="PresenterFlyout"
            FlyoutWidth="450"
            Header="FlyoutPresenter Demo"
            Position="Right"
            ShowCloseButton="False">
            <flyouts:FlyoutPresenter Header="Edit User Profile">
                <flyouts:FlyoutPresenter.Footer>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="80"
                            Margin="0,0,8,0"
                            Click="ClosePresenterFlyout_Click"
                            Content="Cancel" />
                        <Button
                            Width="80"
                            Click="SavePresenterFlyout_Click"
                            Content="Save" />
                    </StackPanel>
                </flyouts:FlyoutPresenter.Footer>

                <StackPanel>
                    <TextBlock Margin="0,0,0,4" Text="First Name" />
                    <TextBox Margin="0,0,0,12" Text="John" />

                    <TextBlock Margin="0,0,0,4" Text="Last Name" />
                    <TextBox Margin="0,0,0,12" Text="Doe" />

                    <TextBlock Margin="0,0,0,4" Text="Email" />
                    <TextBox Margin="0,0,0,12" Text="john.doe@example.com" />

                    <TextBlock Margin="0,0,0,4" Text="Department" />
                    <ComboBox Margin="0,0,0,12" SelectedIndex="0">
                        <ComboBoxItem Content="Engineering" />
                        <ComboBoxItem Content="Marketing" />
                        <ComboBoxItem Content="Sales" />
                        <ComboBoxItem Content="Support" />
                    </ComboBox>

                    <TextBlock Margin="0,0,0,4" Text="Bio" />
                    <TextBox
                        Height="80"
                        AcceptsReturn="True"
                        Text="Software developer with 10 years of experience..."
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </flyouts:FlyoutPresenter>
        </flyouts:Flyout>

        <!--  Focus Trapped Flyout (Default)  -->
        <flyouts:Flyout
            x:Name="FocusTrappedFlyout"
            FlyoutWidth="400"
            Header="Focus Trapped (Default)"
            IsFocusTrapEnabled="True"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Focus Trapping Enabled" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="Try pressing Tab repeatedly. Focus will cycle through the form fields and buttons below, staying within the flyout."
                    TextWrapping="Wrap" />

                <TextBlock Margin="0,0,0,4" Text="Field 1:" />
                <TextBox Margin="0,0,0,12" Text="First field" />

                <TextBlock Margin="0,0,0,4" Text="Field 2:" />
                <TextBox Margin="0,0,0,12" Text="Second field" />

                <TextBlock Margin="0,0,0,4" Text="Field 3:" />
                <TextBox Margin="0,0,0,12" Text="Third field" />

                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                    <Button
                        Width="80"
                        Margin="0,0,8,0"
                        Content="Button 1" />
                    <Button
                        Width="80"
                        Margin="0,0,8,0"
                        Content="Button 2" />
                    <Button
                        Width="80"
                        Click="CloseFlyout_Click"
                        Content="Close"
                        Tag="{Binding ElementName=FocusTrappedFlyout}" />
                </StackPanel>
            </StackPanel>
        </flyouts:Flyout>

        <!--  Focus Free Flyout  -->
        <flyouts:Flyout
            x:Name="FocusFreeFlyout"
            FlyoutWidth="400"
            Header="Focus Free"
            IsFocusTrapEnabled="False"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Text="Focus Trapping Disabled" />
                <TextBlock
                    Margin="0,0,0,16"
                    Text="With IsFocusTrapEnabled=False, pressing Tab can move focus outside the flyout to elements in the main window."
                    TextWrapping="Wrap" />

                <TextBlock Margin="0,0,0,4" Text="Field 1:" />
                <TextBox Margin="0,0,0,12" Text="First field" />

                <TextBlock Margin="0,0,0,4" Text="Field 2:" />
                <TextBox Margin="0,0,0,12" Text="Second field" />

                <Button
                    Width="100"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=FocusFreeFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Branded (Blue) Flyout  -->
        <flyouts:Flyout
            x:Name="BrandedFlyout"
            FlyoutBackground="#1E3A5F"
            FlyoutBorderBrush="#4A90D9"
            FlyoutBorderThickness="2"
            FlyoutWidth="400"
            Header="Branded Panel"
            HeaderBackground="#2C5282"
            HeaderBorderBrush="#4A90D9"
            HeaderForeground="White"
            OverlayBrush="#000080"
            OverlayOpacity="0.3"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Custom Branded Flyout" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#B0C4DE"
                    Text="This flyout demonstrates full color customization using FlyoutBackground, FlyoutBorderBrush, HeaderBackground, HeaderForeground, and HeaderBorderBrush properties."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#B0C4DE"
                    Text="The overlay also uses a custom blue tint with OverlayBrush and reduced OverlayOpacity."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=BrandedFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Success (Green) Flyout  -->
        <flyouts:Flyout
            x:Name="SuccessFlyout"
            FlyoutBackground="#E6F4EA"
            FlyoutBorderBrush="#34A853"
            FlyoutBorderThickness="2"
            FlyoutWidth="400"
            Header="Success"
            HeaderBackground="#34A853"
            HeaderBorderBrush="#34A853"
            HeaderForeground="White"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Foreground="#1E4620"
                    Text="Operation Successful" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#2D6A30"
                    Text="This green-themed flyout is ideal for success messages and confirmations."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#2D6A30"
                    Text="All settings have been saved successfully!"
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=SuccessFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Warning (Orange) Flyout  -->
        <flyouts:Flyout
            x:Name="WarningFlyout"
            FlyoutBackground="#FEF7E0"
            FlyoutBorderBrush="#F9AB00"
            FlyoutBorderThickness="2"
            FlyoutWidth="400"
            Header="Warning"
            HeaderBackground="#F9AB00"
            HeaderBorderBrush="#F9AB00"
            HeaderForeground="White"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Foreground="#7A5A00"
                    Text="Please Review" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#8B6914"
                    Text="This orange-themed flyout is suitable for warnings and important notices."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#8B6914"
                    Text="Please review your changes before continuing."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=WarningFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <!--  Error (Red) Flyout  -->
        <flyouts:Flyout
            x:Name="ErrorFlyout"
            FlyoutBackground="#FCE8E6"
            FlyoutBorderBrush="#EA4335"
            FlyoutBorderThickness="2"
            FlyoutWidth="400"
            Header="Error"
            HeaderBackground="#EA4335"
            HeaderBorderBrush="#EA4335"
            HeaderForeground="White"
            Position="Right">
            <StackPanel Margin="16">
                <TextBlock
                    Margin="0,0,0,16"
                    FontWeight="SemiBold"
                    Foreground="#A50E0E"
                    Text="An Error Occurred" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#B31412"
                    Text="This red-themed flyout is appropriate for error messages and alerts."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,16"
                    Foreground="#B31412"
                    Text="Unable to connect to the server. Please check your network connection and try again."
                    TextWrapping="Wrap" />
                <Button
                    Width="100"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Click="CloseFlyout_Click"
                    Content="Close"
                    Tag="{Binding ElementName=ErrorFlyout}" />
            </StackPanel>
        </flyouts:Flyout>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>
</UserControl>