<TreeView
    x:Class="Atc.Wpf.Sample.SamplesWpfComponentsTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="400"
    d:DesignWidth="230"
    mc:Ignorable="d">

    <TreeViewItem Header="Flyouts">
        <sample:SampleTreeViewItem
            Header="Flyout"
            IsExpanded="True"
            SamplePath="Flyouts.FlyoutView" />
    </TreeViewItem>

    <TreeViewItem Header="Dialogs">
        <sample:SampleTreeViewItem
            Header="Standard DialogBox"
            IsExpanded="True"
            SamplePath="DialogBoxes.StandardDialogBoxView" />
    </TreeViewItem>

    <TreeViewItem Header="Monitoring">
        <sample:SampleTreeViewItem
            Header="ApplicationMonitor"
            IsExpanded="True"
            SamplePath="Monitoring.ApplicationMonitorView" />
    </TreeViewItem>

    <TreeViewItem Header="Notifications">
        <sample:SampleTreeViewItem
            Header="ToastNotification"
            IsExpanded="True"
            SamplePath="Notifications.ToastNotificationView" />
        <sample:SampleTreeViewItem
            Header="ToastNotificationService"
            IsExpanded="True"
            SamplePath="Notifications.ToastNotificationServiceView" />
    </TreeViewItem>

    <TreeViewItem Header="Capture">
        <sample:SampleTreeViewItem
            Header="CaptureService"
            IsExpanded="True"
            SamplePath="Capture.CaptureServiceView" />
    </TreeViewItem>

    <TreeViewItem Header="Printing">
        <sample:SampleTreeViewItem
            Header="PrintService"
            IsExpanded="True"
            SamplePath="Printing.PrintServiceView" />
    </TreeViewItem>

    <TreeViewItem Header="Progressing">
        <sample:SampleTreeViewItem
            Header="BusyIndicatorService"
            IsExpanded="True"
            SamplePath="Progressing.BusyIndicatorServiceView" />
    </TreeViewItem>

    <TreeViewItem Header="Selectors">
        <sample:SampleTreeViewItem
            Header="DualListSelector"
            IsExpanded="True"
            SamplePath="Selectors.DualListSelectorView" />
    </TreeViewItem>

    <TreeViewItem Header="Viewers">
        <sample:SampleTreeViewItem
            Header="JsonViewer"
            IsExpanded="True"
            SamplePath="Viewers.JsonViewerView" />
        <sample:SampleTreeViewItem
            Header="TerminalViewer"
            IsExpanded="True"
            SamplePath="Viewers.TerminalViewerView" />
    </TreeViewItem>

    <TreeViewItem Header="Zoom">
        <sample:SampleTreeViewItem
            Header="ZoomBrowserView"
            IsExpanded="True"
            SamplePath="Zoom.ZoomBrowserViewSampleView" />
    </TreeViewItem>

</TreeView>