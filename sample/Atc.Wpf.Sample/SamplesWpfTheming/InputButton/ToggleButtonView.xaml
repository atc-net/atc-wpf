<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfTheming.InputButton.ToggleButtonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <atc:AutoGrid Columns="*" Rows="Auto,*">


        <GroupBox Header="Usage">
            <ScrollViewer>
                <atc:GridEx Columns="*,10,*" ShowGridLines="True">
                    <atc:UniformSpacingPanel
                        Grid.Column="0"
                        Margin="10"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:UniformSpacingPanel
                            ItemWidth="100"
                            Orientation="Horizontal"
                            Spacing="10">
                            <ToggleButton Content="Off" />
                            <ToggleButton Content="On" IsChecked="True" />
                            <ToggleButton Content="Off" IsEnabled="False" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                IsEnabled="False" />
                        </atc:UniformSpacingPanel>

                        <atc:UniformSpacingPanel
                            ItemWidth="100"
                            Orientation="Horizontal"
                            Spacing="10">
                            <ToggleButton Content="Off" Style="{StaticResource ToggleButtonChromeless}" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                Style="{StaticResource ToggleButtonChromeless}" />
                            <ToggleButton
                                Content="Off"
                                IsEnabled="False"
                                Style="{StaticResource ToggleButtonChromeless}" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                IsEnabled="False"
                                Style="{StaticResource ToggleButtonChromeless}" />
                        </atc:UniformSpacingPanel>

                        <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="10">
                            <ToggleButton Content="Off" Style="{StaticResource ToggleButton.Small}" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                Style="{StaticResource ToggleButton.Small}" />
                            <ToggleButton
                                Content="Off"
                                IsEnabled="False"
                                Style="{StaticResource ToggleButton.Small}" />
                        </atc:UniformSpacingPanel>

                        <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="10">
                            <ToggleButton Content="Off" Style="{StaticResource ToggleButtonChromeless.Small}" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                Style="{StaticResource ToggleButtonChromeless.Small}" />
                            <ToggleButton
                                Content="Off"
                                IsEnabled="False"
                                Style="{StaticResource ToggleButtonChromeless.Small}" />
                        </atc:UniformSpacingPanel>

                        <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="10">
                            <ToggleButton Content="Off" Style="{StaticResource ToggleButton.Large}" />
                            <ToggleButton
                                Content="On"
                                IsChecked="True"
                                Style="{StaticResource ToggleButton.Large}" />
                            <ToggleButton
                                Content="Off"
                                IsEnabled="False"
                                Style="{StaticResource ToggleButton.Large}" />
                        </atc:UniformSpacingPanel>

                        <!--  Glyph toggles (the FontPicker B/I/U/S pattern)  -->
                        <atc:UniformSpacingPanel Orientation="Vertical" Spacing="6">
                            <TextBlock FontWeight="Bold" Text="Glyph toggles (Bold / Italic / Underline / Strikethrough)" />
                            <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="4">
                                <ToggleButton Width="32" Height="28">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="B" />
                                </ToggleButton>
                                <ToggleButton
                                    Width="32"
                                    Height="28"
                                    IsChecked="True">
                                    <TextBlock
                                        FontSize="14"
                                        FontStyle="Italic"
                                        Text="I" />
                                </ToggleButton>
                                <ToggleButton Width="32" Height="28">
                                    <TextBlock
                                        FontSize="14"
                                        Text="U"
                                        TextDecorations="Underline" />
                                </ToggleButton>
                                <ToggleButton
                                    Width="32"
                                    Height="28"
                                    IsChecked="True">
                                    <TextBlock
                                        FontSize="14"
                                        Text="S"
                                        TextDecorations="Strikethrough" />
                                </ToggleButton>
                            </atc:UniformSpacingPanel>
                        </atc:UniformSpacingPanel>

                        <!--  Three-state  -->
                        <atc:UniformSpacingPanel Orientation="Vertical" Spacing="6">
                            <TextBlock FontWeight="Bold" Text="Three-state (IsThreeState=True) — click cycles Off → On → Indeterminate" />
                            <atc:UniformSpacingPanel
                                ItemWidth="120"
                                Orientation="Horizontal"
                                Spacing="10">
                                <ToggleButton Content="Off" IsThreeState="True" />
                                <ToggleButton
                                    Content="On"
                                    IsChecked="True"
                                    IsThreeState="True" />
                                <ToggleButton
                                    Content="Indeterminate"
                                    IsChecked="{x:Null}"
                                    IsThreeState="True" />
                            </atc:UniformSpacingPanel>
                        </atc:UniformSpacingPanel>

                    </atc:UniformSpacingPanel>

                    <atc:UniformSpacingPanel
                        Grid.Column="2"
                        Margin="10"
                        Orientation="Vertical"
                        Spacing="10">

                        <!--  Default size: solid (off) | solid (on) | outline (off) | outline (on)  -->
                        <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="10">

                            <atc:UniformSpacingPanel
                                ItemWidth="100"
                                Orientation="Vertical"
                                Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel
                                ItemWidth="100"
                                Orientation="Vertical"
                                Spacing="10">
                                <ToggleButton
                                    Content="Default"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonDefault}" />
                                <ToggleButton
                                    Content="Primary"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonPrimary}" />
                                <ToggleButton
                                    Content="Secondary"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonSecondary}" />
                                <ToggleButton
                                    Content="Success"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonSuccess}" />
                                <ToggleButton
                                    Content="Danger"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonDanger}" />
                                <ToggleButton
                                    Content="Warning"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonWarning}" />
                                <ToggleButton
                                    Content="Info"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonInfo}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel
                                ItemWidth="100"
                                Orientation="Vertical"
                                Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault.Outline}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary.Outline}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary.Outline}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess.Outline}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger.Outline}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning.Outline}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo.Outline}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel
                                ItemWidth="100"
                                Orientation="Vertical"
                                Spacing="10">
                                <ToggleButton
                                    Content="Default"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonDefault.Outline}" />
                                <ToggleButton
                                    Content="Primary"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonPrimary.Outline}" />
                                <ToggleButton
                                    Content="Secondary"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonSecondary.Outline}" />
                                <ToggleButton
                                    Content="Success"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonSuccess.Outline}" />
                                <ToggleButton
                                    Content="Danger"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonDanger.Outline}" />
                                <ToggleButton
                                    Content="Warning"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonWarning.Outline}" />
                                <ToggleButton
                                    Content="Info"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonInfo.Outline}" />
                            </atc:UniformSpacingPanel>

                        </atc:UniformSpacingPanel>

                        <!--  Small + Large variants  -->
                        <atc:UniformSpacingPanel Orientation="Horizontal" Spacing="10">

                            <atc:UniformSpacingPanel Orientation="Vertical" Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault.Small}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary.Small}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary.Small}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess.Small}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger.Small}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning.Small}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo.Small}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel Orientation="Vertical" Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault.Outline.Small}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary.Outline.Small}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary.Outline.Small}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess.Outline.Small}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger.Outline.Small}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning.Outline.Small}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo.Outline.Small}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel Orientation="Vertical" Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault.Large}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary.Large}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary.Large}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess.Large}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger.Large}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning.Large}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo.Large}" />
                            </atc:UniformSpacingPanel>

                            <atc:UniformSpacingPanel Orientation="Vertical" Spacing="10">
                                <ToggleButton Content="Default" Style="{StaticResource ToggleButtonDefault.Outline.Large}" />
                                <ToggleButton Content="Primary" Style="{StaticResource ToggleButtonPrimary.Outline.Large}" />
                                <ToggleButton Content="Secondary" Style="{StaticResource ToggleButtonSecondary.Outline.Large}" />
                                <ToggleButton Content="Success" Style="{StaticResource ToggleButtonSuccess.Outline.Large}" />
                                <ToggleButton Content="Danger" Style="{StaticResource ToggleButtonDanger.Outline.Large}" />
                                <ToggleButton Content="Warning" Style="{StaticResource ToggleButtonWarning.Outline.Large}" />
                                <ToggleButton Content="Info" Style="{StaticResource ToggleButtonInfo.Outline.Large}" />
                            </atc:UniformSpacingPanel>

                        </atc:UniformSpacingPanel>
                    </atc:UniformSpacingPanel>
                </atc:GridEx>
            </ScrollViewer>
        </GroupBox>
    </atc:AutoGrid>

</UserControl>