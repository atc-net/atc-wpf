<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfSourceGenerators.DependencyPropertyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfSourceGenerators"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    x:Name="UcDependencyProperty"
    d:DataContext="{d:DesignInstance Type=local:DependencyPropertyDemoViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:BusyOverlay IsBusy="{Binding IsRunning}">
                    <TextBlock
                        Margin="100"
                        HorizontalAlignment="Center"
                        Background="Beige"
                        FontSize="36"
                        Text="Hello world" />
                </atc:BusyOverlay>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>
