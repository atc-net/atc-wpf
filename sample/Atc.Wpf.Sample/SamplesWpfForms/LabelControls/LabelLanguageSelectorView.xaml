<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelLanguageSelectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelLanguageSelector
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}"
                    UpdateUiCultureOnChangeEvent="False" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <StackPanel Grid.Column="0" Margin="10">

                        <atc:LabelLanguageSelector Orientation="Horizontal" UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            InformationText="This is a help text.."
                            Orientation="Horizontal"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            Orientation="Horizontal"
                            RenderFlagIndicatorType="None"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="-3"
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Horizontal"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="1031"
                            DropDownFirstItemType="PleaseSelect"
                            Orientation="Horizontal"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False"
                            UseOnlySupportedLanguages="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="de-DE"
                            Orientation="Horizontal"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False"
                            UseOnlySupportedLanguages="False" />

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">

                        <atc:LabelLanguageSelector Orientation="Vertical" UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            InformationText="This is a help text.."
                            Orientation="Vertical"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            Orientation="Vertical"
                            RenderFlagIndicatorType="None"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="-3"
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Vertical"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="1031"
                            DropDownFirstItemType="PleaseSelect"
                            Orientation="Vertical"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False"
                            UseOnlySupportedLanguages="False" />

                        <atc:LabelLanguageSelector
                            DefaultCultureIdentifier="de-DE"
                            Orientation="Vertical"
                            RenderFlagIndicatorType="Shiny16"
                            UpdateUiCultureOnChangeEvent="False"
                            UseOnlySupportedLanguages="False" />

                    </StackPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>