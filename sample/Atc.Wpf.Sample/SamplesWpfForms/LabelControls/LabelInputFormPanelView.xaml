<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelInputFormPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:labelControls="clr-namespace:Atc.Wpf.Sample.SamplesWpfForms.LabelControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <labelControls:LabelInputFormPanelViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <ContentControl Content="{Binding Path=FormPanel}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}">
            <sample:SampleSidePanel.ActionsContent>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Text="Column Layouts" />
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                        <Button Command="{Binding Path=ShowInputForm1ColumnCommand}" Content="1 column" />
                        <Button Command="{Binding Path=ShowInputForm2ColumnsCommand}" Content="2 columns" />
                        <Button Command="{Binding Path=ShowInputForm3ColumnsCommand}" Content="3 columns" />
                        <Button Command="{Binding Path=ShowInputForm4ColumnsCommand}" Content="4 columns" />
                    </atc:UniformSpacingPanel>

                    <TextBlock
                        Margin="0,10,0,5"
                        FontWeight="SemiBold"
                        Text="Address Model" />
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                        <Button Command="{Binding Path=ShowInputFormAddressWithDataCommands}" Content="With data" />
                        <Button Command="{Binding Path=ShowInputFormAddressWithoutDataCommands}" Content="Without data" />
                    </atc:UniformSpacingPanel>

                    <TextBlock
                        Margin="0,10,0,5"
                        FontWeight="SemiBold"
                        Text="Person Model" />
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                        <Button Command="{Binding Path=ShowInputFormPersonWithDataCommands}" Content="With data" />
                        <Button Command="{Binding Path=ShowInputFormPersonWithoutDataCommands}" Content="Without data" />
                    </atc:UniformSpacingPanel>

                    <TextBlock
                        Margin="0,10,0,5"
                        FontWeight="SemiBold"
                        Text="Account Model" />
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="5">
                        <Button Command="{Binding Path=ShowInputFormAccountWithDataCommands}" Content="With data" />
                        <Button Command="{Binding Path=ShowInputFormAccountWithoutDataCommands}" Content="Without data" />
                    </atc:UniformSpacingPanel>
                </StackPanel>
            </sample:SampleSidePanel.ActionsContent>
        </sample:SampleSidePanel>
    </atc:GridEx>
</UserControl>