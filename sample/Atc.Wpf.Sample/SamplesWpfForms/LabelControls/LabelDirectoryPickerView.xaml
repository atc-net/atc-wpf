<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelDirectoryPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelDirectoryPicker
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}"
                    ShowClearTextButton="{Binding ShowClearTextButton}"
                    WatermarkText="{Binding WatermarkText}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <atc:UniformSpacingPanel
                        Grid.Column="0"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelDirectoryPicker LabelText="MyLabel1" Orientation="Horizontal" />

                        <atc:LabelDirectoryPicker
                            IsMandatory="True"
                            LabelText="MyLabel2"
                            Orientation="Horizontal" />

                        <atc:LabelDirectoryPicker
                            IsMandatory="True"
                            LabelText="MyLabel3"
                            Orientation="Horizontal"
                            ShowClearTextButton="True" />

                        <atc:LabelDirectoryPicker
                            AllowOnlyExisting="True"
                            InitialDirectory="C:\Temp"
                            IsMandatory="True"
                            LabelText="MyLabel4"
                            Orientation="Horizontal"
                            ShowClearTextButton="True" />

                        <atc:LabelDirectoryPicker
                            AllowOnlyExisting="True"
                            InitialDirectory="C:\Temp"
                            IsMandatory="True"
                            LabelText="MyLabel5"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            WatermarkText="Select a directory" />

                    </atc:UniformSpacingPanel>
                    <atc:UniformSpacingPanel
                        Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelDirectoryPicker LabelText="MyLabel3" Orientation="Vertical" />

                    </atc:UniformSpacingPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>