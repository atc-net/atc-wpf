<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelColorPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelColorPicker
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <atc:UniformSpacingPanel
                        Grid.Column="0"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelColorPicker
                            x:Name="MyLabelColorPicker1"
                            ColorValue="Green"
                            LabelText="MyLabel1"
                            Orientation="Horizontal" />

                        <atc:LabelColorPicker
                            BrushValue="Blue"
                            IsMandatory="True"
                            LabelText="MyLabel2"
                            Orientation="Horizontal" />

                    </atc:UniformSpacingPanel>
                    <atc:UniformSpacingPanel
                        Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelColorPicker
                            ColorValue="DarkMagenta"
                            LabelText="MyLabel3"
                            Orientation="Vertical"
                            RenderColorIndicatorType="Circle" />

                        <atc:LabelColorPicker
                            BrushValue="DarkOrange"
                            LabelText="MyLabel4"
                            Orientation="Vertical"
                            RenderColorIndicatorType="Circle" />

                    </atc:UniformSpacingPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>