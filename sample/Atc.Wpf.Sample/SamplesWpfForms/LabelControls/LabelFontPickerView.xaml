<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelFontPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfForms.LabelControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:LabelControlDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <!--  Interactive demo  -->
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="Interactive (drives sample text below)" />
                    <atc:LabelFontPicker
                        x:Name="InteractiveLabelFontPicker"
                        InformationText="{Binding Path=InformationText}"
                        IsMandatory="{Binding Path=IsMandatory}"
                        LabelText="{Binding Path=LabelText}"
                        Orientation="{Binding Path=Orientation}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Padding="6"
                        Background="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedBackgroundBrush}"
                        FontFamily="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedFontFamily}"
                        FontSize="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedFontSize}"
                        FontStretch="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedFontStretch}"
                        FontStyle="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedFontStyle}"
                        FontWeight="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedFontWeight}"
                        Foreground="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedForegroundBrush}"
                        Text="The selected font in action — tweak it to your heart's content."
                        TextDecorations="{Binding ElementName=InteractiveLabelFontPicker, Path=SelectedTextDecorations}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <atc:UniformSpacingPanel
                        Grid.Column="0"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelFontPicker
                            x:Name="MyLabelFontPicker1"
                            LabelText="MyLabel1"
                            Orientation="Horizontal"
                            SelectedFontFamily="Arial"
                            SelectedFontSize="14" />

                        <atc:LabelFontPicker
                            IsMandatory="True"
                            LabelText="Family + Size only"
                            Orientation="Horizontal"
                            SelectedFontFamily="Verdana"
                            SelectedFontSize="12"
                            ShowFontStretch="False"
                            ShowFontStyle="False"
                            ShowFontWeight="False" />

                    </atc:UniformSpacingPanel>
                    <atc:UniformSpacingPanel
                        Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="10">

                        <atc:LabelFontPicker
                            LabelText="Vertical layout"
                            Orientation="Vertical"
                            SelectedFontFamily="Tahoma"
                            SelectedFontSize="16" />

                        <atc:LabelFontPicker
                            IsFontFamilyEnabled="False"
                            IsFontSizeEnabled="False"
                            IsFontStretchEnabled="False"
                            LabelText="Family/Size locked"
                            Orientation="Vertical"
                            SelectedFontFamily="Consolas"
                            SelectedFontSize="13" />

                    </atc:UniformSpacingPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>