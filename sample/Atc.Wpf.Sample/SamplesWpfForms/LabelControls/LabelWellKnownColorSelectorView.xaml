<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelWellKnownColorSelectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelWellKnownColorSelector
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <StackPanel Grid.Column="0" Margin="10">

                        <atc:LabelWellKnownColorSelector Orientation="Horizontal" />

                        <atc:LabelWellKnownColorSelector
                            Orientation="Horizontal"
                            SelectedKey="Red"
                            ShowHexCode="True" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelText="MyColor"
                            Orientation="Horizontal"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelWidthNumber="50"
                            LabelWidthSizeDefinition="Percentage"
                            Orientation="Horizontal"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelWidthNumber="120"
                            LabelWidthSizeDefinition="Pixel"
                            Orientation="Horizontal"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            HideAreas="All"
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            LabelWidthNumber="120"
                            LabelWidthSizeDefinition="Pixel"
                            Orientation="Horizontal"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            Orientation="Horizontal"
                            SelectedKey="Red"
                            ShowAsteriskOnMandatory="True"
                            ShowHexCode="True" />

                        <atc:LabelWellKnownColorSelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Horizontal" />

                        <atc:LabelWellKnownColorSelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Horizontal"
                            UseOnlyBasicColors="True" />

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">

                        <atc:LabelWellKnownColorSelector Orientation="Vertical" />

                        <atc:LabelWellKnownColorSelector
                            Orientation="Vertical"
                            SelectedKey="Red"
                            ShowHexCode="True" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelText="MyColor"
                            Orientation="Vertical"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelWidthNumber="50"
                            LabelWidthSizeDefinition="Percentage"
                            Orientation="Vertical"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            LabelWidthNumber="120"
                            LabelWidthSizeDefinition="Pixel"
                            Orientation="Vertical"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            HideAreas="All"
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            LabelWidthNumber="120"
                            LabelWidthSizeDefinition="Pixel"
                            Orientation="Vertical"
                            SelectedKey="Red" />

                        <atc:LabelWellKnownColorSelector
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            Orientation="Vertical"
                            SelectedKey="Red"
                            ShowAsteriskOnMandatory="True"
                            ShowHexCode="True" />

                        <atc:LabelWellKnownColorSelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Vertical" />

                        <atc:LabelWellKnownColorSelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Vertical"
                            UseOnlyBasicColors="True" />

                    </StackPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>