<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelCurrencyBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelCurrencyBox
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <StackPanel Grid.Column="0" Margin="10">

                        <atc:LabelCurrencyBox LabelText="MyLabel1" Orientation="Horizontal" />

                        <atc:LabelCurrencyBox
                            InformationText="This is a help text.."
                            LabelText="MyLabel2"
                            Orientation="Horizontal"
                            PrefixText="@:"
                            SuffixText="XX" />

                        <atc:LabelCurrencyBox
                            HideUpDownButtons="True"
                            InformationText="This is a help text.."
                            LabelText="MyLabel2"
                            Orientation="Horizontal" />

                        <TextBlock
                            Margin="0,10,0,0"
                            FontWeight="Bold"
                            Text="DecimalPlaces examples:" />

                        <atc:LabelCurrencyBox
                            DecimalPlaces="0"
                            LabelText="0 Decimals"
                            Orientation="Horizontal" />

                        <atc:LabelCurrencyBox
                            DecimalPlaces="2"
                            LabelText="2 Decimals"
                            Orientation="Horizontal" />

                        <atc:LabelCurrencyBox
                            DecimalPlaces="4"
                            LabelText="4 Decimals"
                            Orientation="Horizontal" />

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">

                        <atc:LabelCurrencyBox LabelText="MyLabel3" Orientation="Vertical" />

                        <atc:LabelCurrencyBox
                            InformationText="This is a help text.."
                            LabelText="MyLabel4"
                            Orientation="Vertical"
                            PrefixText="@:"
                            SuffixText="XX" />

                        <atc:LabelCurrencyBox
                            HideUpDownButtons="True"
                            InformationText="This is a help text.."
                            LabelText="MyLabel2"
                            Orientation="Vertical" />

                    </StackPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>