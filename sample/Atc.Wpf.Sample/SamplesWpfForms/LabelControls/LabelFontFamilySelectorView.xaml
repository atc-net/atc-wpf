<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelFontFamilySelectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelFontFamilySelector
                    InformationText="{Binding InformationText}"
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    Orientation="{Binding Orientation}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <StackPanel Grid.Column="0" Margin="10">

                        <atc:LabelFontFamilySelector Orientation="Horizontal" />

                        <atc:LabelFontFamilySelector InformationText="This is a help text.." Orientation="Horizontal" />

                        <atc:LabelFontFamilySelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Horizontal" />

                        <atc:LabelFontFamilySelector DropDownFirstItemType="PleaseSelect" Orientation="Horizontal" />

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">

                        <atc:LabelFontFamilySelector Orientation="Vertical" />

                        <atc:LabelFontFamilySelector InformationText="This is a help text.." Orientation="Vertical" />

                        <atc:LabelFontFamilySelector
                            DropDownFirstItemType="PleaseSelect"
                            IsMandatory="True"
                            Orientation="Vertical" />

                    </StackPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>