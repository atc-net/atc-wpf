<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfForms.LabelControls.LabelTextBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:LabelTextBox
                    IsMandatory="{Binding IsMandatory}"
                    LabelText="{Binding LabelText}"
                    InformationText="{Binding InformationText}"
                    Orientation="{Binding Orientation}"
                    ShowClearTextButton="{Binding ShowClearTextButton}"
                    WatermarkText="{Binding WatermarkText}" />

                <atc:GridEx Columns="*,*" ShowGridLines="True">
                    <StackPanel Grid.Column="0" Margin="10">

                        <atc:LabelTextBox
                            x:Name="LtbMyLabel1"
                            LabelText="MyLabel1"
                            Orientation="Horizontal" />

                        <atc:LabelTextBox
                            x:Name="LtbMyLabel2"
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            LabelText="MyLabel2"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            WatermarkText="Fill out with text.." />

                        <atc:LabelTextBox
                            x:Name="LtbEmail"
                            IsMandatory="True"
                            LabelText="Email"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            ValidationFormat="Email"
                            WatermarkText="Email address" />

                        <atc:LabelTextBox
                            HideAreas="AsteriskAndInformation"
                            IsMandatory="True"
                            LabelText="Email"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            ValidationFormat="Email"
                            WatermarkText="Email address" />

                        <atc:LabelTextBox
                            x:Name="LtbFtp"
                            IsMandatory="True"
                            LabelText="Ftp(s) url"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            TriggerOnlyOnLostFocus="False"
                            ValidationFormat="FtpOrFtps"
                            WatermarkText="Ftp url" />

                        <atc:LabelTextBox
                            IsMandatory="True"
                            LabelText="Http(s) url"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            ValidationFormat="HttpOrHttps"
                            WatermarkText="Http url" />

                        <atc:LabelTextBox
                            IsMandatory="True"
                            LabelText="IP address (v4)"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            ValidationFormat="IPv4Address"
                            WatermarkText="IP address" />

                        <atc:LabelTextBox
                            IsMandatory="True"
                            LabelText="OpcTcp url"
                            Orientation="Horizontal"
                            ShowClearTextButton="True"
                            ValidationFormat="OpcTcp"
                            WatermarkText="OpcTcp url" />

                        <atc:LabelTextBox
                            IsMandatory="True"
                            LabelText="Regex [a-z0-9]"
                            Orientation="Horizontal"
                            RegexPattern="^[a-z0-9]+$"
                            ShowClearTextButton="True" />

                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10">

                        <atc:LabelTextBox LabelText="MyLabel3" Orientation="Vertical" />

                        <atc:LabelTextBox
                            InformationColor="Green"
                            InformationText="This is a help text.."
                            IsMandatory="True"
                            LabelText="MyLabel4"
                            Orientation="Vertical"
                            ShowClearTextButton="True"
                            WatermarkText="Fill out with text.." />

                        <atc:LabelTextBox
                            InformationColor="Chocolate"
                            InformationContent="This is a help text.."
                            IsMandatory="True"
                            LabelText="MyLabel5"
                            Orientation="Vertical"
                            ShowClearTextButton="True"
                            WatermarkText="Fill out with text.." />

                        <atc:LabelTextBox
                            IsMandatory="True"
                            LabelText="MyLabel6"
                            Orientation="Vertical"
                            ShowClearTextButton="True"
                            WatermarkText="Fill out with text..">
                            <atc:LabelTextBox.InformationContent>
                                <StackPanel>
                                    <atc:LabelTextInfo LabelText="Info 1" Text="My Info 1" />
                                    <atc:LabelTextInfo LabelText="Info 2" Text="My Info 2" />
                                    <atc:LabelTextInfo LabelText="Info 3" Text="My Info 3" />
                                </StackPanel>
                            </atc:LabelTextBox.InformationContent>
                        </atc:LabelTextBox>

                    </StackPanel>
                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>