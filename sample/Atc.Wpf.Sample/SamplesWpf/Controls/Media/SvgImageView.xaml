<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpf.Controls.Media.SvgImageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcValueConverters="https://github.com/atc-net/atc-wpf/tree/main/schemas/value-converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpf.Controls.Media"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:SvgImageDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <!--  ReSharper disable once MarkupAttributeTypo  -->
                <atc:SvgImage
                    x:Name="MySvgImage"
                    Width="{Binding ImageWidth}"
                    Height="{Binding ImageHeight}"
                    Margin="20"
                    Background="{Binding BackgroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                    ControlSizeType="{Binding ControlSizeType}"
                    Source="/Atc.Wpf.Sample;component/Assets/eggeaster.svg" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>