<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpf.Controls.Layouts.GridExView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <StackPanel>
                    <TextBlock Text="GridEx with Uniform Spacing (10px):" FontWeight="Bold" Margin="0,0,0,5" />
                    <atc:GridEx Rows="Auto,Auto,Auto" Columns="*,*,*" Spacing="10" Margin="0,0,0,15">
                        <Border Background="LightBlue" Padding="10"><TextBlock Text="[0,0]" /></Border>
                        <Border Grid.Column="1" Background="LightGreen" Padding="10"><TextBlock Text="[0,1]" /></Border>
                        <Border Grid.Column="2" Background="LightCoral" Padding="10"><TextBlock Text="[0,2]" /></Border>
                        <Border Grid.Row="1" Background="LightYellow" Padding="10"><TextBlock Text="[1,0]" /></Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="LightPink" Padding="10"><TextBlock Text="[1,1]" /></Border>
                        <Border Grid.Row="1" Grid.Column="2" Background="LightCyan" Padding="10"><TextBlock Text="[1,2]" /></Border>
                        <Border Grid.Row="2" Background="LightGray" Padding="10"><TextBlock Text="[2,0]" /></Border>
                        <Border Grid.Row="2" Grid.Column="1" Background="Lavender" Padding="10"><TextBlock Text="[2,1]" /></Border>
                        <Border Grid.Row="2" Grid.Column="2" Background="PeachPuff" Padding="10"><TextBlock Text="[2,2]" /></Border>
                    </atc:GridEx>

                    <TextBlock Text="GridEx with Separate H/V Spacing (H=20, V=8):" FontWeight="Bold" Margin="0,0,0,5" />
                    <atc:GridEx Rows="Auto,Auto" Columns="Auto,*" HorizontalSpacing="20" VerticalSpacing="8">
                        <TextBlock Text="Label:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" />
                        <TextBlock Grid.Row="1" Text="Value:" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" />
                    </atc:GridEx>
                </StackPanel>

                <UniformGrid>
                    <!--  Grid of 4 colors  -->
                    <atc:GridEx
                        Margin="5"
                        Columns="*,*"
                        Rows="*,*">
                        <Rectangle
                            Grid.Row="0"
                            Grid.Column="0"
                            Fill="Blue" />
                        <Rectangle
                            Grid.Row="0"
                            Grid.Column="1"
                            Fill="Red" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="0"
                            Fill="Green" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="2"
                            Fill="Yellow" />
                    </atc:GridEx>

                    <!--  Colspan Tests (default Orientation)  -->
                    <atc:GridEx
                        Margin="5"
                        Columns="*,*,*"
                        Rows="*,*">
                        <Rectangle
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Fill="Blue" />
                        <Rectangle
                            Grid.Row="0"
                            Grid.Column="2"
                            Fill="Red" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="0"
                            Fill="Yellow" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Fill="Green" />
                    </atc:GridEx>
                </UniformGrid>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>