<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpf.Threading.DebounceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    xmlns:threading="clr-namespace:Atc.Wpf.Sample.SamplesWpf.Threading"
    d:DataContext="{d:DesignInstance Type=threading:DebounceViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <threading:DebounceViewModel />
    </UserControl.DataContext>

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:GridEx
                    Margin="5"
                    Columns="Auto,10,Auto,10,Auto"
                    Rows="Auto,*">

                    <atc:LabelContent
                        x:Name="LcSearch"
                        Grid.Row="0"
                        Grid.Column="0"
                        HideAreas="All"
                        LabelText="Search"
                        LabelWidthNumber="50">
                        <TextBox KeyUp="SearchTextBoxOnKeyup" />
                    </atc:LabelContent>

                    <atc:LabelTextInfo
                        Grid.Row="0"
                        Grid.Column="2"
                        HideAreas="All"
                        LabelText="Status"
                        Text="{Binding Path=Status}" />

                    <atc:LabelTextInfo
                        Grid.Row="0"
                        Grid.Column="4"
                        HideAreas="All"
                        LabelText="Filter"
                        Text="{Binding Path=Filter}" />

                    <ListView
                        Grid.Row="2"
                        Grid.ColumnSpan="5"
                        Margin="0,10,0,0"
                        ItemsSource="{Binding Path=FoundItems}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Path=.}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>