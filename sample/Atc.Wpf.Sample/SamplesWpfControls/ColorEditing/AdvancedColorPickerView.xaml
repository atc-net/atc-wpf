<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.ColorEditing.AdvancedColorPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:colorEditing="clr-namespace:Atc.Wpf.Forms.ColorEditing;assembly=Atc.Wpf.Forms"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <Rectangle
                    Width="100"
                    Height="32"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Fill="{Binding ElementName=AdvancedColorPickerControl, Path=ColorAsBrush}" />
                <colorEditing:AdvancedColorPicker
                    x:Name="AdvancedColorPickerControl"
                    ShowArgb="{Binding ShowArgb}"
                    ShowAvailableColors="{Binding ShowAvailableColors}"
                    ShowBeforeAfterColorResult="{Binding ShowBeforeAfterColorResult}"
                    ShowHsv="{Binding ShowHsv}"
                    ShowHueSlider="{Binding ShowHueSlider}"
                    ShowRgba="{Binding ShowRgba}"
                    ShowSaturationBrightnessPicker="{Binding ShowSaturationBrightnessPicker}"
                    ShowStandardColors="{Binding ShowStandardColors}"
                    ShowTransparencySlider="{Binding ShowTransparencySlider}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>

</UserControl>