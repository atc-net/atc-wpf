<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.FontEditing.AdvancedFontPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fontEditing="clr-namespace:Atc.Wpf.Forms.FontEditing;assembly=Atc.Wpf.Forms"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.FontEditing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:AdvancedFontPickerDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <fontEditing:AdvancedFontPicker
                    x:Name="AdvancedFontPickerControl"
                    IsBackgroundColorEnabled="{Binding Path=IsBackgroundColorEnabled}"
                    IsFontFamilyEnabled="{Binding Path=IsFontFamilyEnabled}"
                    IsFontSizeEnabled="{Binding Path=IsFontSizeEnabled}"
                    IsFontStretchEnabled="{Binding Path=IsFontStretchEnabled}"
                    IsFontStyleEnabled="{Binding Path=IsFontStyleEnabled}"
                    IsFontWeightEnabled="{Binding Path=IsFontWeightEnabled}"
                    IsForegroundColorEnabled="{Binding Path=IsForegroundColorEnabled}"
                    IsTextDecorationsEnabled="{Binding Path=IsTextDecorationsEnabled}"
                    PreviewText="{Binding Path=PreviewText, Mode=TwoWay}"
                    SelectedFontFamily="Segoe UI"
                    SelectedFontSize="14"
                    ShowBackgroundColor="{Binding Path=ShowBackgroundColor}"
                    ShowFontFamily="{Binding Path=ShowFontFamily}"
                    ShowFontSize="{Binding Path=ShowFontSize}"
                    ShowFontStretch="{Binding Path=ShowFontStretch}"
                    ShowFontStyle="{Binding Path=ShowFontStyle}"
                    ShowFontWeight="{Binding Path=ShowFontWeight}"
                    ShowForegroundColor="{Binding Path=ShowForegroundColor}"
                    ShowPreview="{Binding Path=ShowPreview}"
                    ShowQuickToggles="{Binding Path=ShowQuickToggles}"
                    ShowTextDecorations="{Binding Path=ShowTextDecorations}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>

</UserControl>