<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.Inputs.FontPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.Inputs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:FontPickerDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <!--  Interactive demo  -->
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="Interactive (drives sample text below)" />
                    <atc:FontPicker
                        x:Name="InteractiveFontPicker"
                        IsBackgroundColorEnabled="{Binding Path=IsBackgroundColorEnabled}"
                        IsFontFamilyEnabled="{Binding Path=IsFontFamilyEnabled}"
                        IsFontSizeEnabled="{Binding Path=IsFontSizeEnabled}"
                        IsFontStretchEnabled="{Binding Path=IsFontStretchEnabled}"
                        IsFontStyleEnabled="{Binding Path=IsFontStyleEnabled}"
                        IsFontWeightEnabled="{Binding Path=IsFontWeightEnabled}"
                        IsForegroundColorEnabled="{Binding Path=IsForegroundColorEnabled}"
                        IsTextDecorationsEnabled="{Binding Path=IsTextDecorationsEnabled}"
                        PreviewText="{Binding Path=PreviewText}"
                        ShowBackgroundColor="{Binding Path=ShowBackgroundColor}"
                        ShowFontFamily="{Binding Path=ShowFontFamily}"
                        ShowFontSize="{Binding Path=ShowFontSize}"
                        ShowFontStretch="{Binding Path=ShowFontStretch}"
                        ShowFontStyle="{Binding Path=ShowFontStyle}"
                        ShowFontWeight="{Binding Path=ShowFontWeight}"
                        ShowForegroundColor="{Binding Path=ShowForegroundColor}"
                        ShowPreview="{Binding Path=ShowPreview}"
                        ShowQuickToggles="{Binding Path=ShowQuickToggles}"
                        ShowTextDecorations="{Binding Path=ShowTextDecorations}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Padding="6"
                        Background="{Binding ElementName=InteractiveFontPicker, Path=SelectedBackgroundBrush}"
                        FontFamily="{Binding ElementName=InteractiveFontPicker, Path=SelectedFontFamily}"
                        FontSize="{Binding ElementName=InteractiveFontPicker, Path=SelectedFontSize}"
                        FontStretch="{Binding ElementName=InteractiveFontPicker, Path=SelectedFontStretch}"
                        FontStyle="{Binding ElementName=InteractiveFontPicker, Path=SelectedFontStyle}"
                        FontWeight="{Binding ElementName=InteractiveFontPicker, Path=SelectedFontWeight}"
                        Foreground="{Binding ElementName=InteractiveFontPicker, Path=SelectedForegroundBrush}"
                        Text="The selected font in action — tweak it to your heart's content."
                        TextDecorations="{Binding ElementName=InteractiveFontPicker, Path=SelectedTextDecorations}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  Showcase: various FontPicker examples  -->
                <atc:UniformSpacingPanel
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">

                    <TextBlock FontWeight="Bold" Text="Default (all properties enabled)" />
                    <atc:FontPicker SelectedFontSize="14" />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="Bold"
                        Text="Family + Size only (Weight/Style/Stretch hidden)" />
                    <atc:FontPicker
                        SelectedFontFamily="Arial"
                        SelectedFontSize="12"
                        ShowFontStretch="False"
                        ShowFontStyle="False"
                        ShowFontWeight="False" />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="Bold"
                        Text="Family locked (only Weight/Style editable)" />
                    <atc:FontPicker
                        IsFontFamilyEnabled="False"
                        IsFontSizeEnabled="False"
                        IsFontStretchEnabled="False"
                        SelectedFontFamily="Verdana"
                        SelectedFontSize="16" />

                </atc:UniformSpacingPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>

</UserControl>