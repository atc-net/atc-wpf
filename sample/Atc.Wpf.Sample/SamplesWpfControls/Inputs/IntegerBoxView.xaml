<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.Inputs.IntegerBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <!--  Interactive demo  -->
                <atc:IntegerBox
                    Width="300"
                    HorizontalAlignment="Left"
                    ButtonsAlignment="{Binding ButtonsAlignment}"
                    HideUpDownButtons="{Binding HideUpDownButtons}"
                    Interval="{Binding Interval}"
                    IsReadOnly="{Binding IsReadOnly}"
                    Maximum="{Binding Maximum}"
                    Minimum="{Binding Minimum}"
                    PrefixText="{Binding PrefixText}"
                    SuffixText="{Binding SuffixText}"
                    SwitchUpDownButtons="{Binding SwitchUpDownButtons}"
                    Value="{Binding Value}" />

                <!--  Showcase: Button Alignments  -->
                <atc:UniformSpacingPanel
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">
                    <atc:IntegerBox ButtonsAlignment="Right" SwitchUpDownButtons="False" />
                    <atc:IntegerBox ButtonsAlignment="Right" SwitchUpDownButtons="True" />
                    <atc:IntegerBox ButtonsAlignment="Left" SwitchUpDownButtons="False" />
                    <atc:IntegerBox ButtonsAlignment="Left" SwitchUpDownButtons="True" />
                    <atc:IntegerBox ButtonsAlignment="Opposite" SwitchUpDownButtons="False" />
                    <atc:IntegerBox ButtonsAlignment="Opposite" SwitchUpDownButtons="True" />
                </atc:UniformSpacingPanel>

                <!--  Showcase: Special States  -->
                <atc:UniformSpacingPanel
                    Margin="10"
                    Orientation="Vertical"
                    Spacing="10">
                    <atc:IntegerBox
                        atc:TextBoxHelper.Watermark="Hello Watermark..."
                        atc:TextBoxHelper.WatermarkAlignment="Center"
                        PrefixText="P123"
                        SuffixText="S123" />
                    <atc:IntegerBox IsEnabled="False" />
                    <atc:IntegerBox IsReadOnly="True" />
                </atc:UniformSpacingPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>

</UserControl>