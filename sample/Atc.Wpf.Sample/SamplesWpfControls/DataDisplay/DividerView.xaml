<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.DividerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!--  Interactive demo  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Interactive Demo">
                    <StackPanel x:Name="UsageArea" Margin="20">
                        <atc:Divider
                            Content="{Binding Content}"
                            LineStrokeThickness="{Binding LineStrokeThickness}"
                            Orientation="{Binding Orientation}" />
                    </StackPanel>
                </GroupBox>

                <!--  Static examples  -->
                <GroupBox Padding="10" Header="Examples">
                    <StackPanel>
                        <StackPanel Margin="20" Orientation="Horizontal">
                            <atc:SvgImage
                                Width="50"
                                Height="50"
                                Source="/Atc.Wpf.Controls;component/Resources/Icons/info_help.svg" />

                            <atc:Divider Orientation="Vertical" />

                            <atc:SvgImage
                                Width="50"
                                Height="50"
                                Source="/Atc.Wpf.Controls;component/Resources/Icons/info_help.svg" />

                            <atc:Divider LineStroke="Orange" Orientation="Vertical" />

                            <atc:SvgImage
                                Width="50"
                                Height="50"
                                Source="/Atc.Wpf.Controls;component/Resources/Icons/info_help.svg" />
                        </StackPanel>

                        <atc:Divider
                            LineStroke="Green"
                            LineStrokeDashArray="5"
                            LineStrokeThickness="2"
                            Orientation="Horizontal" />
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <GroupBox
            Grid.Column="1"
            atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
            Header="Properties">
            <sample:SamplePropertyController SourceObject="{Binding}" />
        </GroupBox>

    </Grid>

</UserControl>