<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.ChipView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.DataDisplay"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:DoubleToCornerRadiusValueConverter x:Key="DoubleToCornerRadiusConverter" />
    </UserControl.Resources>

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <!--  Interactive demo  -->
                <dataDisplay:Chip
                    CanRemove="{Binding CanRemove}"
                    Content="{Binding Content}"
                    CornerRadius="{Binding CornerRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}"
                    IsClickable="{Binding IsClickable}"
                    IsSelectable="{Binding IsSelectable}"
                    IsSelected="{Binding ChipIsSelected}"
                    Size="{Binding Size}"
                    Variant="{Binding Variant}" />

                <!--  Chip Variants  -->
                <atc:UniformSpacingPanel
                    HorizontalSpacing="10"
                    Orientation="Horizontal"
                    VerticalSpacing="10">
                    <dataDisplay:Chip Content="Default" Variant="Default" />
                    <dataDisplay:Chip Content="Filter" Variant="Filter" />
                    <dataDisplay:Chip Content="Input" Variant="Input" />
                    <dataDisplay:Chip Content="Action" Variant="Action" />
                </atc:UniformSpacingPanel>

                <!--  Chip Sizes  -->
                <atc:UniformSpacingPanel
                    VerticalAlignment="Center"
                    HorizontalSpacing="15"
                    Orientation="Horizontal"
                    VerticalSpacing="10">
                    <dataDisplay:Chip Content="Small" Size="Small" />
                    <dataDisplay:Chip Content="Medium" Size="Medium" />
                    <dataDisplay:Chip Content="Large" Size="Large" />
                </atc:UniformSpacingPanel>

                <!--  Custom Styling  -->
                <atc:UniformSpacingPanel
                    HorizontalSpacing="10"
                    Orientation="Horizontal"
                    VerticalSpacing="10">
                    <dataDisplay:Chip
                        Background="#E3F2FD"
                        BorderBrush="#2196F3"
                        Content="Info"
                        Foreground="#1565C0" />
                    <dataDisplay:Chip
                        Background="#E8F5E9"
                        BorderBrush="#4CAF50"
                        Content="Success"
                        Foreground="#2E7D32" />
                    <dataDisplay:Chip
                        Background="#FFF3E0"
                        BorderBrush="#FF9800"
                        Content="Warning"
                        Foreground="#E65100" />
                    <dataDisplay:Chip
                        Background="#FFEBEE"
                        BorderBrush="#F44336"
                        Content="Error"
                        Foreground="#C62828" />
                    <dataDisplay:Chip Content="Disabled" IsEnabled="False" />
                </atc:UniformSpacingPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>
</UserControl>