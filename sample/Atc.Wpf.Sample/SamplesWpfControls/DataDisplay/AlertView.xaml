<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.AlertView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!--  Interactive demo  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Interactive Demo">
                    <dataDisplay:Alert
                        x:Name="UsageArea"
                        Content="{Binding Content}"
                        IsDense="{Binding IsDense}"
                        IsDismissible="{Binding IsDismissible}"
                        IsPulsing="{Binding IsPulsing}"
                        PulseDuration="{Binding PulseDuration}"
                        PulseOpacity="{Binding PulseOpacity}"
                        Severity="{Binding Severity}"
                        ShowIcon="{Binding ShowIcon}"
                        Variant="{Binding Variant}" />
                </GroupBox>

                <!--  Showcase: Severity Levels  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Severity Levels">
                    <atc:UniformSpacingPanel Orientation="Vertical" VerticalSpacing="8">
                        <dataDisplay:Alert Severity="Info">Informational alert</dataDisplay:Alert>
                        <dataDisplay:Alert Severity="Success">Success alert</dataDisplay:Alert>
                        <dataDisplay:Alert Severity="Warning">Warning alert</dataDisplay:Alert>
                        <dataDisplay:Alert Severity="Error">Error alert</dataDisplay:Alert>
                    </atc:UniformSpacingPanel>
                </GroupBox>

                <!--  Showcase: Variants  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Variants">
                    <atc:UniformSpacingPanel Orientation="Vertical" VerticalSpacing="8">
                        <dataDisplay:Alert Severity="Info" Variant="Filled">Filled</dataDisplay:Alert>
                        <dataDisplay:Alert Severity="Info" Variant="Outlined">Outlined</dataDisplay:Alert>
                        <dataDisplay:Alert Severity="Info" Variant="Text">Text</dataDisplay:Alert>
                    </atc:UniformSpacingPanel>
                </GroupBox>

                <!--  Showcase: Pulsing  -->
                <GroupBox Padding="10" Header="Pulsing Animation">
                    <atc:UniformSpacingPanel Orientation="Vertical" VerticalSpacing="8">
                        <dataDisplay:Alert IsPulsing="True" Severity="Warning">
                            Default pulse (1.5s duration, 0.65 opacity).
                        </dataDisplay:Alert>
                        <dataDisplay:Alert
                            IsPulsing="True"
                            PulseDuration="0:0:0.75"
                            PulseOpacity="0.4"
                            Severity="Error"
                            Variant="Filled">
                            Fast deep-fade pulse (0.75s, 0.4 opacity).
                        </dataDisplay:Alert>
                    </atc:UniformSpacingPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <GroupBox
            Grid.Column="1"
            atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
            Header="Properties">
            <sample:SamplePropertyController SourceObject="{Binding}" />
        </GroupBox>

    </Grid>

</UserControl>