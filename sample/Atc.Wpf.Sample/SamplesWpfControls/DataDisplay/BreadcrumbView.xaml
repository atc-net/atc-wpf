<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.BreadcrumbView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="800"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!--  Interactive demo  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Interactive Demo">
                    <StackPanel>
                        <dataDisplay:Breadcrumb
                            x:Name="UsageArea"
                            MaxVisibleItems="{Binding MaxVisibleItems}"
                            OverflowMode="{Binding OverflowMode}"
                            Separator="{Binding Separator}">
                            <dataDisplay:BreadcrumbItem Content="Home" />
                            <dataDisplay:BreadcrumbItem Content="Products" />
                            <dataDisplay:BreadcrumbItem Content="Electronics" />
                            <dataDisplay:BreadcrumbItem Content="Laptops" />
                            <dataDisplay:BreadcrumbItem Content="Gaming" />
                        </dataDisplay:Breadcrumb>
                    </StackPanel>
                </GroupBox>

                <!--  Showcase: Clickable with Events  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Clickable with Events">
                    <StackPanel>
                        <dataDisplay:Breadcrumb x:Name="ClickableBreadcrumb" ItemClicked="OnBreadcrumbItemClicked">
                            <dataDisplay:BreadcrumbItem Content="Dashboard" />
                            <dataDisplay:BreadcrumbItem Content="Users" />
                            <dataDisplay:BreadcrumbItem Content="John Doe" />
                            <dataDisplay:BreadcrumbItem Content="Orders" />
                        </dataDisplay:Breadcrumb>
                        <TextBlock
                            x:Name="NavigationStatus"
                            Margin="0,10,0,0"
                            FontStyle="Italic"
                            Foreground="Gray"
                            Text="Click a breadcrumb item to navigate..." />
                    </StackPanel>
                </GroupBox>

                <!--  Showcase: Custom Separators  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Custom Separators">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontWeight="Bold"
                            Text="Chevron icon via SeparatorTemplate" />
                        <dataDisplay:Breadcrumb>
                            <dataDisplay:Breadcrumb.SeparatorTemplate>
                                <DataTemplate>
                                    <Path
                                        Margin="2,0"
                                        VerticalAlignment="Center"
                                        Data="M 0,0 L 4,4 L 0,8"
                                        Stroke="{DynamicResource AtcApps.Brushes.Gray5}"
                                        StrokeThickness="1.5" />
                                </DataTemplate>
                            </dataDisplay:Breadcrumb.SeparatorTemplate>
                            <dataDisplay:BreadcrumbItem Content="Root" />
                            <dataDisplay:BreadcrumbItem Content="Documents" />
                            <dataDisplay:BreadcrumbItem Content="Projects" />
                            <dataDisplay:BreadcrumbItem Content="MyProject" />
                        </dataDisplay:Breadcrumb>
                    </StackPanel>
                </GroupBox>

                <!--  Showcase: Overflow Mode  -->
                <GroupBox Padding="10" Header="Overflow Mode">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                            OverflowMode=Collapsed with MaxVisibleItems=2.
                        </TextBlock>
                        <dataDisplay:Breadcrumb MaxVisibleItems="2" OverflowMode="Collapsed">
                            <dataDisplay:BreadcrumbItem Content="Root" />
                            <dataDisplay:BreadcrumbItem Content="Level 1" />
                            <dataDisplay:BreadcrumbItem Content="Level 2" />
                            <dataDisplay:BreadcrumbItem Content="Level 3" />
                            <dataDisplay:BreadcrumbItem Content="Current" />
                        </dataDisplay:Breadcrumb>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <GroupBox
            Grid.Column="1"
            atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
            Header="Properties">
            <sample:SamplePropertyController SourceObject="{Binding}" />
        </GroupBox>

    </Grid>

</UserControl>