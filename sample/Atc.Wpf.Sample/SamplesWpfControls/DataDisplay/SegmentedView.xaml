<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.SegmentedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.DataDisplay"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="800"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:DoubleToCornerRadiusValueConverter x:Key="DoubleToCornerRadiusConverter" />
    </UserControl.Resources>

    <atc:GridEx Columns="*,400">

        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <!--  Interactive demo  -->
                <dataDisplay:Segmented
                    CornerRadius="{Binding CornerRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}"
                    EqualSegmentWidth="{Binding EqualSegmentWidth}"
                    SelectedIndex="{Binding SelectedIndex}">
                    <dataDisplay:SegmentedItem Content="Day" />
                    <dataDisplay:SegmentedItem Content="Week" />
                    <dataDisplay:SegmentedItem Content="Month" />
                    <dataDisplay:SegmentedItem Content="Year" />
                </dataDisplay:Segmented>

                <!--  With Icons  -->
                <dataDisplay:Segmented SelectedIndex="0">
                    <dataDisplay:SegmentedItem Content="List">
                        <dataDisplay:SegmentedItem.Icon>
                            <TextBlock FontSize="14" Text="&#x2630;" />
                        </dataDisplay:SegmentedItem.Icon>
                    </dataDisplay:SegmentedItem>
                    <dataDisplay:SegmentedItem Content="Grid">
                        <dataDisplay:SegmentedItem.Icon>
                            <TextBlock FontSize="14" Text="&#x25A6;" />
                        </dataDisplay:SegmentedItem.Icon>
                    </dataDisplay:SegmentedItem>
                    <dataDisplay:SegmentedItem Content="Map">
                        <dataDisplay:SegmentedItem.Icon>
                            <TextBlock FontSize="14" Text="&#x2691;" />
                        </dataDisplay:SegmentedItem.Icon>
                    </dataDisplay:SegmentedItem>
                </dataDisplay:Segmented>

                <!--  Interactive with Event  -->
                <StackPanel>
                    <dataDisplay:Segmented
                        x:Name="InteractiveSegmented"
                        SelectedIndex="0"
                        SelectionChanged="OnSelectionChanged">
                        <dataDisplay:SegmentedItem Content="All" />
                        <dataDisplay:SegmentedItem Content="Active" />
                        <dataDisplay:SegmentedItem Content="Completed" />
                        <dataDisplay:SegmentedItem Content="Archived" />
                    </dataDisplay:Segmented>
                    <TextBlock
                        x:Name="SelectionStatus"
                        Margin="0,10,0,0"
                        FontStyle="Italic"
                        Foreground="Gray"
                        Text="Click a segment to see the selection change event." />
                </StackPanel>

                <!--  Sizing &amp; Styling  -->
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontWeight="Bold"
                        Text="Proportional width (EqualSegmentWidth=False)" />
                    <dataDisplay:Segmented EqualSegmentWidth="False" SelectedIndex="1">
                        <dataDisplay:SegmentedItem Content="S" />
                        <dataDisplay:SegmentedItem Content="Medium" />
                        <dataDisplay:SegmentedItem Content="Extra Large" />
                    </dataDisplay:Segmented>

                    <TextBlock
                        Margin="0,15,0,10"
                        FontWeight="Bold"
                        Text="Custom colors" />
                    <dataDisplay:Segmented
                        CornerRadius="12"
                        SelectedBackground="#4CAF50"
                        SelectedForeground="White"
                        SelectedIndex="0">
                        <dataDisplay:SegmentedItem Content="Low" />
                        <dataDisplay:SegmentedItem Content="Medium" />
                        <dataDisplay:SegmentedItem Content="High" />
                    </dataDisplay:Segmented>
                </StackPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>

        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />

    </atc:GridEx>
</UserControl>