<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.CardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.DataDisplay"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="1200"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:DoubleToCornerRadiusValueConverter x:Key="DoubleToCornerRadiusConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!--  Interactive demo  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Interactive Demo">
                    <dataDisplay:Card
                        x:Name="UsageArea"
                        Width="400"
                        HorizontalAlignment="Left"
                        CornerRadius="{Binding CornerRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}"
                        Elevation="{Binding Elevation}"
                        ExpanderButtonLocation="{Binding ExpanderButtonLocation}"
                        Header="{Binding Header}"
                        IsExpandable="{Binding IsExpandable}"
                        IsExpanded="{Binding IsExpanded}"
                        ShowHeader="{Binding ShowHeader}">
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                    </dataDisplay:Card>
                </GroupBox>

                <!--  Showcase: Elevation Levels  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Elevation Levels">
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="20"
                        Orientation="Horizontal"
                        VerticalSpacing="10">
                        <dataDisplay:Card
                            Width="100"
                            Elevation="0"
                            Header="Flat">
                            <TextBlock Text="Elevation 0" />
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="100"
                            Elevation="1"
                            Header="Level 1">
                            <TextBlock Text="Elevation 1" />
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="100"
                            Elevation="2"
                            Header="Default">
                            <TextBlock Text="Elevation 2" />
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="100"
                            Elevation="3"
                            Header="Level 3">
                            <TextBlock Text="Elevation 3" />
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="100"
                            Elevation="5"
                            Header="Raised">
                            <TextBlock Text="Elevation 5" />
                        </dataDisplay:Card>
                    </atc:UniformSpacingPanel>
                </GroupBox>

                <!--  Showcase: Expandable Card  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Expandable Cards">
                    <StackPanel>
                        <dataDisplay:Card
                            Width="400"
                            Margin="0,0,0,15"
                            HorizontalAlignment="Left"
                            Header="Advanced Settings"
                            IsExpandable="True">
                            <StackPanel>
                                <TextBlock Text="Timeout (seconds):" />
                                <TextBox
                                    Width="100"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Text="30" />
                            </StackPanel>
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="400"
                            HorizontalAlignment="Left"
                            ExpanderButtonLocation="Right"
                            Header="Right Toggle"
                            IsExpandable="True"
                            IsExpanded="False">
                            <TextBlock Text="Initially collapsed with right-side toggle." />
                        </dataDisplay:Card>
                    </StackPanel>
                </GroupBox>

                <!--  Showcase: Dashboard Grid  -->
                <GroupBox Padding="10" Header="Card Grid Layout">
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="16"
                        Orientation="Horizontal"
                        VerticalSpacing="16">
                        <dataDisplay:Card
                            Width="180"
                            Elevation="2"
                            Header="Dashboard">
                            <StackPanel>
                                <TextBlock FontSize="24" Text="42" />
                                <TextBlock Foreground="Gray" Text="Active Users" />
                            </StackPanel>
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="180"
                            Elevation="2"
                            Header="Analytics">
                            <StackPanel>
                                <TextBlock FontSize="24" Text="1,234" />
                                <TextBlock Foreground="Gray" Text="Page Views" />
                            </StackPanel>
                        </dataDisplay:Card>
                        <dataDisplay:Card
                            Width="180"
                            Elevation="2"
                            Header="Revenue">
                            <StackPanel>
                                <TextBlock FontSize="24" Text="$9,876" />
                                <TextBlock Foreground="Gray" Text="This Month" />
                            </StackPanel>
                        </dataDisplay:Card>
                    </atc:UniformSpacingPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <GroupBox
            Grid.Column="1"
            atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
            Header="Properties">
            <sample:SamplePropertyController SourceObject="{Binding}" />
        </GroupBox>

    </Grid>

</UserControl>