<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.DataDisplay.AvatarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataDisplay="clr-namespace:Atc.Wpf.Controls.DataDisplay;assembly=Atc.Wpf.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!--  Interactive demo  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Interactive Demo">
                    <dataDisplay:Avatar
                        x:Name="UsageArea"
                        HorizontalAlignment="Center"
                        DisplayName="{Binding DisplayName}"
                        Initials="{Binding Initials}"
                        Size="{Binding Size}"
                        Status="{Binding Status}" />
                </GroupBox>

                <!--  Showcase: Sizes  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Size Presets">
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="30"
                        Orientation="Horizontal"
                        VerticalSpacing="20">
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar DisplayName="John Doe" Size="ExtraSmall" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="ExtraSmall" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar DisplayName="John Doe" Size="Small" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Small" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar DisplayName="John Doe" Size="Medium" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Medium" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar DisplayName="John Doe" Size="Large" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Large" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar DisplayName="John Doe" Size="ExtraLarge" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="ExtraLarge" />
                        </StackPanel>
                    </atc:UniformSpacingPanel>
                </GroupBox>

                <!--  Showcase: Status Indicators  -->
                <GroupBox
                    Margin="0,0,0,10"
                    Padding="10"
                    Header="Status Indicators">
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="30"
                        Orientation="Horizontal"
                        VerticalSpacing="20">
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar
                                DisplayName="Online"
                                Size="Large"
                                Status="Online" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Online" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar
                                DisplayName="Away"
                                Size="Large"
                                Status="Away" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Away" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar
                                DisplayName="Busy"
                                Size="Large"
                                Status="Busy" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Busy" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar
                                DisplayName="DND"
                                Size="Large"
                                Status="DoNotDisturb" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="DoNotDisturb" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:Avatar
                                DisplayName="Offline"
                                Size="Large"
                                Status="Offline" />
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Offline" />
                        </StackPanel>
                    </atc:UniformSpacingPanel>
                </GroupBox>

                <!--  Showcase: Avatar Group  -->
                <GroupBox Padding="10" Header="Avatar Group">
                    <atc:UniformSpacingPanel
                        HorizontalSpacing="50"
                        Orientation="Horizontal"
                        VerticalSpacing="20">
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:AvatarGroup MaxVisible="3" Size="Medium">
                                <dataDisplay:Avatar DisplayName="Alice Johnson" />
                                <dataDisplay:Avatar DisplayName="Bob Smith" />
                                <dataDisplay:Avatar DisplayName="Carol Williams" />
                                <dataDisplay:Avatar DisplayName="David Brown" />
                                <dataDisplay:Avatar DisplayName="Eve Davis" />
                            </dataDisplay:AvatarGroup>
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="5 Avatars (MaxVisible=3)" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <dataDisplay:AvatarGroup MaxVisible="4" Size="Large">
                                <dataDisplay:Avatar DisplayName="Team Member 1" />
                                <dataDisplay:Avatar DisplayName="Team Member 2" />
                                <dataDisplay:Avatar DisplayName="Team Member 3" />
                                <dataDisplay:Avatar DisplayName="Team Member 4" />
                                <dataDisplay:Avatar DisplayName="Team Member 5" />
                            </dataDisplay:AvatarGroup>
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="Large Size Group" />
                        </StackPanel>
                    </atc:UniformSpacingPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <GroupBox Grid.Column="1" Header="Properties">
            <sample:SamplePropertyController SourceObject="{Binding}" />
        </GroupBox>

    </Grid>

</UserControl>