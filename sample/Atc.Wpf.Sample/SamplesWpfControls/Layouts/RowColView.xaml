<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.Layouts.RowColView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:grid="clr-namespace:Atc.Wpf.Controls.Layouts.Grid;assembly=Atc.Wpf.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <grid:Row x:Name="InteractiveRow" Gutter="{Binding Spacing}">
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#E3F2FD">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#BBDEFB">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#90CAF9">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                </grid:Row>

                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="Basic Row with Equal Columns" />
                <grid:Row Margin="0,0,0,15" Gutter="16">
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#E3F2FD">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#BBDEFB">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                    <grid:Col Span="8">
                        <Border Padding="16" Background="#90CAF9">
                            <TextBlock HorizontalAlignment="Center" Text="Col Span=8" />
                        </Border>
                    </grid:Col>
                </grid:Row>

                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="Responsive Layout (resize window to see changes)" />
                <grid:Row Margin="0,0,0,15" Gutter="16">
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="6"
                                Md="8"
                                Sm="12"
                                Xl="4"
                                Xs="24"
                                Xxl="4" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#C8E6C9">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Column 1" />
                                <TextBlock FontSize="10" Text="Xs=24, Sm=12, Md=8, Lg=6" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="6"
                                Md="8"
                                Sm="12"
                                Xl="4"
                                Xs="24"
                                Xxl="4" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#A5D6A7">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Column 2" />
                                <TextBlock FontSize="10" Text="Xs=24, Sm=12, Md=8, Lg=6" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="6"
                                Md="8"
                                Sm="12"
                                Xl="4"
                                Xs="24"
                                Xxl="4" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#81C784">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Column 3" />
                                <TextBlock FontSize="10" Text="Xs=24, Sm=12, Md=8, Lg=6" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="6"
                                Md="8"
                                Sm="12"
                                Xl="4"
                                Xs="24"
                                Xxl="4" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#66BB6A">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Column 4" />
                                <TextBlock FontSize="10" Text="Xs=24, Sm=12, Md=8, Lg=6" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                </grid:Row>

                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="Sidebar + Content Layout" />
                <grid:Row Gutter="16">
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="6"
                                Md="8"
                                Sm="24"
                                Xl="4"
                                Xs="24"
                                Xxl="4" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#FFF3E0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Sidebar" />
                                <TextBlock Text="Navigation" />
                                <TextBlock Text="Links" />
                                <TextBlock Text="Settings" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                    <grid:Col>
                        <grid:Col.Layout>
                            <grid:ColLayout
                                Lg="18"
                                Md="16"
                                Sm="24"
                                Xl="20"
                                Xs="24"
                                Xxl="20" />
                        </grid:Col.Layout>
                        <Border Padding="16" Background="#FFE0B2">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Main Content" />
                                <TextBlock Text="This area takes up the remaining space. On small screens, both columns stack vertically." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </grid:Col>
                </grid:Row>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>