<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.Layouts.UniformSpacingPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.Layouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:UniformSpacingPanelDemoViewModel}"
    d:DesignHeight="900" d:DesignWidth="900" mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="BaseRectangle" TargetType="{x:Type Rectangle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="30" />
        </Style>
        <Style
            x:Key="BlueRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Blue" />
        </Style>
        <Style
            x:Key="RedRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Red" />
        </Style>
        <Style
            x:Key="GreenRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Green" />
        </Style>
        <Style
            x:Key="YellowRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Yellow" />
        </Style>
        <Style
            x:Key="CoralRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Coral" />
        </Style>
        <Style
            x:Key="CyanRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Cyan" />
        </Style>
        <Style
            x:Key="FuchsiaRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Fuchsia" />
        </Style>
        <Style
            x:Key="LimeRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Lime" />
        </Style>
        <Style
            x:Key="OliveRectangle"
            BasedOn="{StaticResource BaseRectangle}"
            TargetType="{x:Type Rectangle}">
            <Setter Property="Fill" Value="Olive" />
        </Style>
    </UserControl.Resources>

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:UniformSpacingPanel
                    x:Name="InteractiveUniformSpacingPanel"
                    Background="Silver"
                    Orientation="{Binding Orientation}"
                    Spacing="{Binding Spacing}">
                    <Rectangle Style="{StaticResource BlueRectangle}" />
                    <Rectangle Style="{StaticResource RedRectangle}" />
                    <Rectangle Style="{StaticResource OliveRectangle}" />
                    <Rectangle Style="{StaticResource GreenRectangle}" />
                    <Rectangle Style="{StaticResource YellowRectangle}" />
                    <Rectangle Style="{StaticResource CyanRectangle}" />
                </atc:UniformSpacingPanel>

                <atc:GridEx
                    Margin="0,10,0,0"
                    Columns="300,300"
                    Rows="Auto,Auto"
                    ShowGridLines="True">

                    <atc:UniformSpacingPanel
                        Grid.Row="0"
                        Grid.Column="0"
                        Background="Silver"
                        HorizontalSpacing="{Binding HorizontalSpacing}"
                        Orientation="Horizontal"
                        VerticalSpacing="{Binding VerticalSpacing}">
                        <Rectangle Style="{StaticResource BlueRectangle}" />
                        <Rectangle Style="{StaticResource RedRectangle}" />
                        <Rectangle Style="{StaticResource OliveRectangle}" />
                        <Rectangle Style="{StaticResource GreenRectangle}" />
                        <Rectangle Style="{StaticResource YellowRectangle}" />
                        <Rectangle Style="{StaticResource CyanRectangle}" />
                        <Rectangle Style="{StaticResource FuchsiaRectangle}" />
                        <Rectangle Style="{StaticResource CoralRectangle}" />
                        <Rectangle Style="{StaticResource LimeRectangle}" />
                    </atc:UniformSpacingPanel>

                    <atc:UniformSpacingPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Background="DarkGray"
                        Orientation="Horizontal"
                        Spacing="{Binding UniformSpacing}">
                        <Rectangle Style="{StaticResource BlueRectangle}" />
                        <Rectangle Style="{StaticResource RedRectangle}" />
                        <Rectangle Style="{StaticResource OliveRectangle}" />
                        <Rectangle Style="{StaticResource GreenRectangle}" />
                        <Rectangle Style="{StaticResource YellowRectangle}" />
                        <Rectangle Style="{StaticResource CyanRectangle}" />
                        <Rectangle Style="{StaticResource FuchsiaRectangle}" />
                        <Rectangle Style="{StaticResource CoralRectangle}" />
                        <Rectangle Style="{StaticResource LimeRectangle}" />
                    </atc:UniformSpacingPanel>

                    <atc:UniformSpacingPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Width="200"
                        Background="DarkTurquoise"
                        HorizontalSpacing="{Binding HorizontalSpacing}"
                        Orientation="Vertical"
                        VerticalSpacing="{Binding VerticalSpacing}">
                        <Rectangle Style="{StaticResource BlueRectangle}" />
                        <Rectangle Style="{StaticResource RedRectangle}" />
                        <Rectangle Style="{StaticResource OliveRectangle}" />
                        <Rectangle Style="{StaticResource GreenRectangle}" />
                        <Rectangle Style="{StaticResource YellowRectangle}" />
                        <Rectangle Style="{StaticResource CyanRectangle}" />
                        <Rectangle Style="{StaticResource FuchsiaRectangle}" />
                        <Rectangle Style="{StaticResource CoralRectangle}" />
                        <Rectangle Style="{StaticResource LimeRectangle}" />
                    </atc:UniformSpacingPanel>

                    <atc:UniformSpacingPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Width="200"
                        Background="DarkCyan"
                        Orientation="Vertical"
                        Spacing="{Binding UniformSpacing}">
                        <Rectangle Style="{StaticResource BlueRectangle}" />
                        <Rectangle Style="{StaticResource RedRectangle}" />
                        <Rectangle Style="{StaticResource OliveRectangle}" />
                        <Rectangle Style="{StaticResource GreenRectangle}" />
                        <Rectangle Style="{StaticResource YellowRectangle}" />
                        <Rectangle Style="{StaticResource CyanRectangle}" />
                        <Rectangle Style="{StaticResource FuchsiaRectangle}" />
                        <Rectangle Style="{StaticResource CoralRectangle}" />
                        <Rectangle Style="{StaticResource LimeRectangle}" />
                    </atc:UniformSpacingPanel>

                </atc:GridEx>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>