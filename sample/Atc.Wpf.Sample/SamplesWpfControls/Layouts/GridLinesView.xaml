<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfControls.Layouts.GridLinesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcValueConverters="https://github.com/atc-net/atc-wpf/tree/main/schemas/value-converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfControls.Layouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:GridLinesDemoViewModel}"
    d:DesignHeight="900" d:DesignWidth="900" mc:Ignorable="d">
    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel
                x:Name="UsageArea"
                Style="{StaticResource SampleUsageAreaStyle}">

                <atc:GridLines
                    x:Name="InteractiveGridLines"
                    Height="200"
                    HorizontalStep="{Binding Spacing}"
                    VerticalStep="{Binding Spacing}" />

                <atc:GridLines
                    Margin="0,10,0,0"
                    Height="200"
                    HorizontalStep="{Binding HorizontalStep}"
                    LineBrush="{Binding LineBrushColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                    VerticalStep="{Binding VerticalStep}"
                    Visibility="{Binding IsVisible, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}}" />

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>