<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfFontIcons.FontIconView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcValueConverters="https://github.com/atc-net/atc-wpf/tree/main/schemas/value-converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fontIcons="clr-namespace:Atc.Wpf.FontIcons;assembly=Atc.Wpf.FontIcons"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfFontIcons"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:FontIconDemoViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <WrapPanel Orientation="Horizontal">

                    <fontIcons:FontAwesomeBrand
                        x:Name="Fab"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeBrandIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeBrand
                        x:Name="Iab"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeBrandIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontAwesomeRegular
                        x:Name="Far"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeRegularIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeRegular
                        x:Name="Iar"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeRegularIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontAwesomeSolid
                        x:Name="Fas"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeSolidIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeSolid
                        x:Name="Ias"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeSolidIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontAwesomeBrand7
                        x:Name="Fab7"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeBrand7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeBrand7
                        x:Name="Iab7"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeBrand7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontAwesomeRegular7
                        x:Name="Far7"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeRegular7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeRegular7
                        x:Name="Iar7"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeRegular7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontAwesomeSolid7
                        x:Name="Fas7"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeSolid7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageAwesomeSolid7
                        x:Name="Ias7"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontAwesomeSolid7Icon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontBootstrap
                        x:Name="Fb"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontBootstrapIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageBootstrap
                        x:Name="Ib"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontBootstrapIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:IcoFont
                        x:Name="Ico"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding IcoFontIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageIcoFont
                        x:Name="Iico"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding IcoFontIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontMaterialDesign
                        x:Name="Fmd"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontMaterialDesignIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageMaterialDesign
                        x:Name="Imd"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontMaterialDesignIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:FontWeather
                        x:Name="Fw"
                        Margin="10"
                        HorizontalAlignment="Center"
                        FlipOrientation="{Binding FlipOrientation}"
                        FontSize="{Binding FontSize}"
                        Foreground="{Binding FontForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontWeatherIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />
                    <fontIcons:ImageWeather
                        x:Name="Iw"
                        Width="{Binding ImageSize}"
                        Height="{Binding ImageSize}"
                        Margin="10"
                        FlipOrientation="{Binding FlipOrientation}"
                        Foreground="{Binding ImageForegroundColor, Converter={x:Static atcValueConverters:ColorToBrushValueConverter.Instance}}"
                        Icon="{Binding FontWeatherIcon}"
                        Spin="{Binding Spin}"
                        SpinDuration="{Binding SpinDuration}" />

                </WrapPanel>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>
</UserControl>