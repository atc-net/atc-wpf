<UserControl
    x:Class="Atc.Wpf.Sample.SamplesWpfFontIcons.FontIconViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Sample.SamplesWpfFontIcons"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:Atc.Wpf.Controls.Sample;assembly=Atc.Wpf.Controls.Sample"
    d:DataContext="{d:DesignInstance Type=local:FontIconViewerDemoViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,400">
        <ScrollViewer Grid.Column="0" Style="{StaticResource SampleScrollViewerStyle}">
            <atc:UniformSpacingPanel x:Name="UsageArea" Style="{StaticResource SampleUsageAreaStyle}">

                <atc:BusyOverlay DisplayAfter="0" IsBusy="{Binding IsBusy}">
                    <ItemsControl ItemsSource="{Binding IconsView}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:IconItem}">
                                <StackPanel
                                    Width="150"
                                    Margin="20"
                                    Orientation="Vertical"
                                    ToolTip="{Binding ToolTip}">
                                    <Image
                                        Width="50"
                                        Height="50"
                                        HorizontalAlignment="Center">
                                        <Image.Source>
                                            <MultiBinding Converter="{x:Static local:FontIconViewerImageConverter.Instance}">
                                                <Binding Path="EnumValue" />
                                                <Binding Path="DataContext.IconColor" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding DisplayName}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </atc:BusyOverlay>

            </atc:UniformSpacingPanel>
        </ScrollViewer>
        <sample:SampleSidePanel Grid.Column="1" SourceObject="{Binding}" />
    </atc:GridEx>

</UserControl>