<UserControl
    x:Class="Atc.Wpf.Controls.Sample.SampleSidePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Controls.Sample"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Margin="10,0,10,0"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!--  Properties  -->
            <GroupBox atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}" Header="Properties">
                <local:SamplePropertyController x:Name="PropertyController" />
            </GroupBox>

            <!--  Data (only visible when ViewModel has a SampleDataGenerator)  -->
            <GroupBox
                x:Name="DataGroupBox"
                Margin="0,4,0,0"
                atc:HeaderedControlHelper.HeaderBackground="{DynamicResource AtcApps.Brushes.Accent4}"
                Header="Data"
                Visibility="Collapsed">
                <local:SampleDataController x:Name="DataController" />
            </GroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>