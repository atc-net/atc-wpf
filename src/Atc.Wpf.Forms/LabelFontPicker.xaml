<labelControls:LabelControl
    x:Class="Atc.Wpf.Forms.LabelFontPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atcTranslation="https://github.com/atc-net/atc-wpf/tree/main/schemas/translations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:formsBaseControls="clr-namespace:Atc.Wpf.Forms.BaseControls"
    xmlns:labelControls="clr-namespace:Atc.Wpf.Forms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=labelControls:LabelFontPicker}"
    IsTabStop="False"
    mc:Ignorable="d">

    <labelControls:LabelContent
        HideAreas="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=HideAreas}"
        InformationColor="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=InformationColor}"
        InformationContent="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=InformationContent}"
        InformationText="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=InformationText}"
        IsMandatory="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsMandatory}"
        IsTabStop="False"
        LabelPosition="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=LabelPosition}"
        LabelText="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=LabelText, FallbackValue=Font}"
        LabelWidthNumber="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=LabelWidthNumber}"
        LabelWidthSizeDefinition="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=LabelWidthSizeDefinition}"
        MandatoryColor="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=MandatoryColor}"
        Orientation="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Orientation}"
        ShowAsteriskOnMandatory="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ShowAsteriskOnMandatory}"
        ValidationColor="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ValidationColor}"
        ValidationText="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ValidationText}">

        <formsBaseControls:FontPicker
            ColorEditorMode="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ColorEditorMode}"
            IsBackgroundColorEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsBackgroundColorEnabled}"
            IsFontFamilyEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsFontFamilyEnabled}"
            IsFontSizeEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsFontSizeEnabled}"
            IsFontStretchEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsFontStretchEnabled}"
            IsFontStyleEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsFontStyleEnabled}"
            IsFontWeightEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsFontWeightEnabled}"
            IsForegroundColorEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsForegroundColorEnabled}"
            IsTextDecorationsEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=IsTextDecorationsEnabled}"
            PreviewText="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=PreviewText, Mode=TwoWay}"
            SelectedBackgroundBrush="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedBackgroundBrush, Mode=TwoWay}"
            SelectedFontFamily="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedFontFamily, Mode=TwoWay}"
            SelectedFontSize="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedFontSize, Mode=TwoWay}"
            SelectedFontStretch="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedFontStretch, Mode=TwoWay}"
            SelectedFontStyle="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedFontStyle, Mode=TwoWay}"
            SelectedFontWeight="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedFontWeight, Mode=TwoWay}"
            SelectedForegroundBrush="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedForegroundBrush, Mode=TwoWay}"
            SelectedTextDecorations="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=SelectedTextDecorations, Mode=TwoWay}"
            ShowBackgroundColor="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowBackgroundColor}"
            ShowFontFamily="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowFontFamily}"
            ShowFontSize="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowFontSize}"
            ShowFontStretch="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowFontStretch}"
            ShowFontStyle="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowFontStyle}"
            ShowFontWeight="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowFontWeight}"
            ShowForegroundColor="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowForegroundColor}"
            ShowPreview="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowPreview}"
            ShowQuickToggles="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowQuickToggles}"
            ShowTextDecorations="{Binding RelativeSource={RelativeSource AncestorType={x:Type labelControls:LabelFontPicker}}, Path=ShowTextDecorations}" />

    </labelControls:LabelContent>

</labelControls:LabelControl>