<dialogs:NiceDialogBox
    x:Class="Atc.Wpf.Forms.Dialogs.FontPickerDialogBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcValueConverters="https://github.com/atc-net/atc-wpf/tree/main/schemas/value-converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Atc.Wpf.Theming.Themes.Dialogs;assembly=Atc.Wpf.Theming"
    xmlns:fontEditing="clr-namespace:Atc.Wpf.Forms.FontEditing"
    xmlns:local="clr-namespace:Atc.Wpf.Forms.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Path=Settings.TitleBarText}"
    d:DataContext="{d:DesignInstance Type=local:FontPickerDialogBox,
                                     IsDesignTimeCreatable=False}"
    d:Height="720"
    d:Width="910"
    mc:Ignorable="d">

    <DockPanel>

        <Border
            Height="50"
            Background="{DynamicResource AtcApps.Brushes.ThemeBackground1}"
            BorderBrush="{DynamicResource AtcApps.Brushes.Accent}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top"
            Visibility="{Binding Path=HeaderControl, Converter={x:Static atcValueConverters:ObjectNotNullToVisibilityVisibleValueConverter.Instance}}">
            <ContentControl Margin="30" Content="{Binding Path=HeaderControl}" />
        </Border>

        <Border
            Height="50"
            Background="{DynamicResource AtcApps.Brushes.ThemeBackground1}"
            BorderBrush="{DynamicResource AtcApps.Brushes.Accent}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <atc:UniformSpacingPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="20"
                Visibility="{Binding Path=Settings.ShowNegativeButton, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}}">
                <Button
                    Width="100"
                    Height="30"
                    Background="{Binding Path=Settings.AffirmativeButtonBackground}"
                    Click="OnOkClick"
                    Content="{Binding Path=Settings.AffirmativeButtonText, FallbackValue=OK}"
                    Foreground="{Binding Path=Settings.AffirmativeButtonForeground}"
                    IsDefault="True" />
                <Button
                    Width="100"
                    Height="30"
                    Background="{Binding Path=Settings.NegativeButtonBackground}"
                    Click="OnCancelClick"
                    Content="{Binding Path=Settings.NegativeButtonText, FallbackValue=Cancel}"
                    Foreground="{Binding Path=Settings.NegativeButtonForeground}"
                    IsCancel="True" />
            </atc:UniformSpacingPanel>
        </Border>

        <fontEditing:AdvancedFontPicker
            x:Name="UcAdvancedFontPicker"
            Margin="10"
            IsBackgroundColorEnabled="{Binding Path=IsBackgroundColorEnabled}"
            IsFontFamilyEnabled="{Binding Path=IsFontFamilyEnabled}"
            IsFontSizeEnabled="{Binding Path=IsFontSizeEnabled}"
            IsFontStretchEnabled="{Binding Path=IsFontStretchEnabled}"
            IsFontStyleEnabled="{Binding Path=IsFontStyleEnabled}"
            IsFontWeightEnabled="{Binding Path=IsFontWeightEnabled}"
            IsForegroundColorEnabled="{Binding Path=IsForegroundColorEnabled}"
            IsTextDecorationsEnabled="{Binding Path=IsTextDecorationsEnabled}"
            PreviewText="{Binding Path=PreviewText, Mode=TwoWay}"
            SelectedBackgroundBrush="{Binding Path=SelectedBackgroundBrush, Mode=TwoWay}"
            SelectedForegroundBrush="{Binding Path=SelectedForegroundBrush, Mode=TwoWay}"
            SelectedTextDecorations="{Binding Path=SelectedTextDecorations, Mode=TwoWay}"
            ShowBackgroundColor="{Binding Path=ShowBackgroundColor}"
            ShowFontFamily="{Binding Path=ShowFontFamily}"
            ShowFontSize="{Binding Path=ShowFontSize}"
            ShowFontStretch="{Binding Path=ShowFontStretch}"
            ShowFontStyle="{Binding Path=ShowFontStyle}"
            ShowFontWeight="{Binding Path=ShowFontWeight}"
            ShowForegroundColor="{Binding Path=ShowForegroundColor}"
            ShowPreview="{Binding Path=ShowPreview}"
            ShowQuickToggles="{Binding Path=ShowQuickToggles}"
            ShowTextDecorations="{Binding Path=ShowTextDecorations}" />

    </DockPanel>

</dialogs:NiceDialogBox>