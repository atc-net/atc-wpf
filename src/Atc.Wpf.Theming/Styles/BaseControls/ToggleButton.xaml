<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Atc.Wpf.Theming;component/Styles/BaseControls/Button.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Base ToggleButton style. Inherits the full Button visual template (which targets
        ButtonBase) and adds an IsChecked trigger that swaps Background/BorderBrush to the
        existing Pressed brushes — so checked state has the same depressed look as the
        IsPressed state and uses the same colour vocabulary every Bootstrap-style variant
        already defines via atc:ControlsHelper.Pressed*Brush.
    -->
    <Style
        x:Key="AtcApps.Styles.ToggleButton"
        BasedOn="{StaticResource AtcApps.Styles.Button}"
        TargetType="{x:Type ToggleButton}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=(atc:ControlsHelper.PressedBackgroundBrush)}" />
                <Setter Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource Self}, Path=(atc:ControlsHelper.PressedBorderBrush)}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="AtcApps.Styles.ToggleButton.Small"
        BasedOn="{StaticResource AtcApps.Styles.ToggleButton}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="Padding" Value="2,0" />
    </Style>

    <Style
        x:Key="AtcApps.Styles.ToggleButton.Large"
        BasedOn="{StaticResource AtcApps.Styles.ToggleButton}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="FontSize" Value="{StaticResource AtcApps.Font.Size.Button.Large}" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style
        x:Key="ToggleButton.Small"
        BasedOn="{StaticResource AtcApps.Styles.ToggleButton.Small}"
        TargetType="{x:Type ToggleButton}" />

    <Style
        x:Key="ToggleButton.Large"
        BasedOn="{StaticResource AtcApps.Styles.ToggleButton.Large}"
        TargetType="{x:Type ToggleButton}" />

