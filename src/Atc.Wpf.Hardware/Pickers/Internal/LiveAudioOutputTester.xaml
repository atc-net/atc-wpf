<UserControl
    x:Class="Atc.Wpf.Hardware.Pickers.Internal.LiveAudioOutputTester"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:Atc.Wpf.Hardware.Resources"
    x:ClassModifier="internal"
    Background="{DynamicResource AtcApps.Brushes.Gray9}"
    SnapsToDevicePixels="True"
    mc:Ignorable="d">

    <atc:GridEx Columns="*,Auto">
        <Grid Grid.Column="0">
            <Canvas
                x:Name="PartCanvas"
                ClipToBounds="True"
                SizeChanged="OnCanvasSizeChanged">
                <Polyline
                    x:Name="PartTopLine"
                    Stroke="{DynamicResource AtcApps.Brushes.Accent}"
                    StrokeThickness="1.0" />
                <Polyline
                    x:Name="PartBottomLine"
                    Stroke="{DynamicResource AtcApps.Brushes.Accent}"
                    StrokeThickness="1.0" />
                <Rectangle
                    x:Name="PartPeakBar"
                    Width="6"
                    Fill="{DynamicResource AtcApps.Brushes.Accent}" />
            </Canvas>
            <TextBlock
                x:Name="PartError"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontStyle="Italic"
                Foreground="{DynamicResource AtcApps.Brushes.Accent}"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
        </Grid>

        <Button
            x:Name="PartTestButton"
            Grid.Column="1"
            MinWidth="64"
            Margin="6,0,0,0"
            Padding="8,2"
            VerticalAlignment="Center"
            Click="OnTestButtonClick"
            Content="{x:Static resources:Miscellaneous.Test}" />
    </atc:GridEx>
</UserControl>