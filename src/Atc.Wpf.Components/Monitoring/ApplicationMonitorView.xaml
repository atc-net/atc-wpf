<UserControl
    x:Class="Atc.Wpf.Components.Monitoring.ApplicationMonitorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcTranslation="https://github.com/atc-net/atc-wpf/tree/main/schemas/translations"
    xmlns:atcValueConverters="https://github.com/atc-net/atc-wpf/tree/main/schemas/value-converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Atc.Wpf.Components.Monitoring"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ApplicationMonitorViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <atc:GridEx Columns="*" Rows="Auto,*">
        <DockPanel Grid.Row="0">
            <ToolBarTray Visibility="{Binding Path=ShowToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                <ToolBar ToolBarTray.IsLocked="True">
                    <Button Command="{Binding Path=ClearCommand}" Visibility="{Binding Path=ShowClearInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                        <Image
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0"
                            Source="pack://application:,,,/Atc.Wpf.Components;component/Resources/Images/eraser.png"
                            ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                          Key=ClearAll}" />
                    </Button>

                    <ToggleButton IsChecked="{Binding Path=AutoScroll, Mode=TwoWay}" Visibility="{Binding Path=ShowAutoScrollInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                        <Image
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0"
                            Source="pack://application:,,,/Atc.Wpf.Components;component/Resources/Images/scrollrefresh.png"
                            ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                          Key=Auto}" />
                    </ToggleButton>

                    <ToggleButton
                        IsChecked="{Binding Path=IsPaused, Mode=TwoWay}"
                        ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                      Key=PauseResumeIncomingEntriesTooltip}"
                        Visibility="{Binding Path=ShowPauseInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                        <StackPanel Orientation="Horizontal">
                            <Grid
                                Width="16"
                                Height="16"
                                Margin="1,1,0,0">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="{Binding Path=IsPaused, Converter={x:Static local:PausedToGlyphValueConverter.Instance}}" />
                            </Grid>
                            <Border
                                Margin="4,0,0,0"
                                Padding="4,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AtcApps.Brushes.Accent}"
                                CornerRadius="6"
                                Visibility="{Binding Path=BufferedCount, Converter={x:Static atcValueConverters:IntegerGreaterThenZeroToVisibilityVisibleValueConverter.Instance}}">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding Path=BufferedCount}" />
                            </Border>
                        </StackPanel>
                    </ToggleButton>

                    <Separator Margin="5,0" />

                    <ToggleButton Command="{Binding Path=FilterChangeCommand}" IsChecked="{Binding Path=Filter.SeverityError, Mode=TwoWay}">
                        <Image
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0"
                            Source="pack://application:,,,/Atc.Wpf.Components;component/Resources/Images/error.png"
                            ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                          Key=Errors}" />
                    </ToggleButton>

                    <ToggleButton Command="{Binding Path=FilterChangeCommand}" IsChecked="{Binding Path=Filter.SeverityWarning, Mode=TwoWay}">
                        <Image
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0"
                            Source="pack://application:,,,/Atc.Wpf.Components;component/Resources/Images/warning.png"
                            ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                          Key=Warnings}" />
                    </ToggleButton>

                    <ToggleButton Command="{Binding Path=FilterChangeCommand}" IsChecked="{Binding Path=Filter.SeverityInformation, Mode=TwoWay}">
                        <Image
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0"
                            Source="pack://application:,,,/Atc.Wpf.Components;component/Resources/Images/information.png"
                            ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                          Key=Information}" />
                    </ToggleButton>

                    <Separator Margin="5,0" />

                    <TextBox
                        Width="150"
                        Text="{Binding Path=MatchOnText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding Path=ShowSearchInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}" />

                    <Separator
                        Margin="5,0"
                        Visibility="{Binding Path=ShowExportInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}" />

                    <Button
                        Command="{Binding Path=ExportCommand}"
                        ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                      Key=ExportVisibleEntriesTooltip}"
                        Visibility="{Binding Path=ShowExportInToolbar, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                        <Grid
                            Width="16"
                            Height="16"
                            Margin="1,1,0,0">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="⤓" />
                        </Grid>
                    </Button>
                </ToolBar>
            </ToolBarTray>
        </DockPanel>
        <Grid Grid.Row="1">
            <ListView
                x:Name="LvEntries"
                ItemsSource="{Binding Path=Entries}"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.IsDeferredScrollingEnabled="False"
                ScrollViewer.ScrollChanged="OnListViewScrollChanged"
                SelectedItem="{Binding Path=SelectedEntry, Mode=TwoWay}"
                SelectionChanged="OnEntriesSelectionChanged"
                SelectionMode="Extended"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <!--  ReSharper disable Xaml.BindingWithContextNotResolved  -->
                        <MenuItem Command="{Binding Path=PlacementTarget.DataContext.CopySelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous, Key=CopySelectedToClipboard}" />
                        <MenuItem Command="{Binding Path=PlacementTarget.DataContext.CopyAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous, Key=CopyAllToClipboard}" />
                        <!--  ReSharper restore Xaml.BindingWithContextNotResolved  -->
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="120" Header="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous, Key=Timestamp}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="local:ApplicationEventEntry">
                                    <TextBlock Text="{Binding Path=Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="28">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="local:ApplicationEventEntry">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="{Binding Path=LogCategoryTypeImage}">
                                        <Image.ToolTip>
                                            <ToolTip Content="{Binding Path=LogCategoryTypeToolTip}" />
                                        </Image.ToolTip>
                                    </Image>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous, Key=Area}">
                            <GridViewColumn.Width>
                                <MultiBinding Converter="{x:Static atcValueConverters:BoolAndDoubleToDoubleMultiValueConverter.Instance}">
                                    <Binding Path="ShowColumnArea" />
                                    <Binding Path="AreaColumnWidth" RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}" />
                                </MultiBinding>
                            </GridViewColumn.Width>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="local:ApplicationEventEntry">
                                    <TextBlock Text="{Binding Path=Area}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="{Binding Path=MessageColumnWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}" Header="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous, Key=Message}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="local:ApplicationEventEntry">
                                    <TextBlock Text="{Binding Path=Message}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>

            <Button
                Margin="0,0,16,16"
                Padding="10,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{DynamicResource AtcApps.Brushes.Accent}"
                Click="OnJumpToLiveClick"
                Foreground="White"
                ToolTip="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                              Key=ResumeTailModeTooltip}"
                Visibility="{Binding Path=IsDetachedFromTail, Converter={x:Static atcValueConverters:BoolToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{atcTranslation:Resx ResxName=Atc.Wpf.Controls.Resources.Miscellaneous,
                                                   Key=JumpToLive}" />
                    <Border
                        Margin="6,0,0,0"
                        Padding="4,0"
                        VerticalAlignment="Center"
                        Background="White"
                        CornerRadius="6"
                        Visibility="{Binding Path=NewSinceDetached, Converter={x:Static atcValueConverters:IntegerGreaterThenZeroToVisibilityVisibleValueConverter.Instance}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}">
                        <TextBlock
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AtcApps.Brushes.Accent}"
                            Text="{Binding Path=NewSinceDetached, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ApplicationMonitorView}}}" />
                    </Border>
                </StackPanel>
            </Button>
        </Grid>
    </atc:GridEx>

</UserControl>