{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Atc.Wpf/Atc.Wpf.csproj",
            "src/Atc.Wpf.Controls/Atc.Wpf.Controls.csproj",
            "src/Atc.Wpf.Forms/Atc.Wpf.Forms.csproj",
            "src/Atc.Wpf.Components/Atc.Wpf.Components.csproj",
            "src/Atc.Wpf.FontIcons/Atc.Wpf.FontIcons.csproj",
            "src/Atc.Wpf.Theming/Atc.Wpf.Theming.csproj",
            "src/Atc.Wpf.Network/Atc.Wpf.Network.csproj",
            "src/Atc.Wpf.UndoRedo/Atc.Wpf.UndoRedo.csproj"
          ],
          "src": "."
        }
      ],
      "dest": "docs/api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "allowCompilationErrors": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "src": "docs",
        "dest": "."
      },
      {
        "files": [
          "index.md",
          "toc.yml"
        ],
        "src": ".",
        "dest": "."
      }
    ],
    "resource": [
      {
        "files": [
          "docs/images/**"
        ],
        "src": ".",
        "dest": "."
      }
    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appName": "Atc.Wpf",
      "_appTitle": "Atc.Wpf — WPF control library",
      "_appFooter": "ATC.Net WPF · MIT License · <a href=\"https://github.com/atc-net/atc-wpf\">GitHub</a>",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/atc-net/atc-wpf",
        "branch": "main"
      }
    }
  }
}